---
/**
 * Home — One System portfolio.
 * Ported from _reference/home-design-v5-converged.html. Chrome (console rail,
 * footer, theme, fonts) lives in Base.astro. Repeated pieces are extracted to
 * components; hero / bento / modules / journal / close stay inline here.
 *
 * ALL body copy is placeholder until Phase 4 (CLAUDE.md). No metrics, clients,
 * roles, or claims are invented; text matches the approved mockup verbatim.
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import headshot from '../assets/headshot-4x5.jpg';
import SectionLabel from '../components/SectionLabel.astro';
import DisciplineStrip from '../components/DisciplineStrip.astro';
import WorkIndex from '../components/WorkIndex.astro';
import StatFigure from '../components/StatFigure.astro';

// Curated "Selected work" for the home index. The featured pair (SPORTIME + The
// Ninth) is showcased in the Bento above, so it's omitted here; the full set
// lives on /work (linked via "View all").
const SELECTED = ['dealnews', 'raa', 'agency-fiveeighty', 'level', 'wisp'];
const allWork = await getCollection('work');
const bySlug = new Map(allWork.map((e) => [e.data.slug, e]));
const selectedWork = SELECTED.map((s) => bySlug.get(s)).filter((e) => e !== undefined);

---

<Base
  title="Pratik Mehta · Creative & Marketing Strategist"
  description="I build creative, social, and performance as one system. Creative & Marketing Strategist in New York, with an AI-forward workflow."
>
  {/* SPLIT HERO */}
  <section class="hero">
    <div class="hero-inner">
      <div>
        <div class="kick rev">Open to creative or marketing leadership roles · New York</div>
        <h1 class="rev page-h1">I build creative, social, and performance as <span class="signal">one system.</span></h1>
        <p class="lead rev">I connect the making of the creative to the marketing system that makes it perform, and own it from the idea to what it does after it ships.</p>
        <div class="btn-row rev"><a class="btn btn-p" href="/work">See the work →</a><a class="btn btn-g" href="/contact">Start a conversation →</a></div>
      </div>
      <figure class="hero-figure rev">
        {/* 1:1 brand-mark animation. Self-hosted (public/hero), webm→mp4.
            Loops, pauses off-screen + on click; reduced-motion shows the
            poster still and never autoplays. JS hook: data-hero-video. */}
        <div class="frame">
          <button class="hero-video" type="button" data-hero-video
            aria-label="Play or pause the intro animation" aria-pressed="true">
            <video
              poster="/hero/home/poster.webp"
              width="1080" height="1080"
              muted loop playsinline autoplay preload="metadata"
            >
              <source src="/hero/home/hero_1080.webm" type="video/webm" />
              <source src="/hero/home/hero_1080.mp4" type="video/mp4" />
            </video>
            <span class="hero-video-state" aria-hidden="true">❚❚ Pause</span>
          </button>
        </div>
      </figure>
    </div>
  </section>

  {/* DISCIPLINES STRIP */}
  <DisciplineStrip />

  {/* BENTO — featured */}
  <section class="block" id="featured">
    <SectionLabel code="01" title="Featured" />
    <div class="bento rev">
      <div class="feat-row">
        <a class="tile t-feat" href="/work/sportime-clubs">
          <span class="badge client">Client</span>
          <div class="img"><div class="ph-fill ph-bg ph-16x9"></div></div>
          <div class="meta">
            <div>
              <h3 class="h3">SPORTIME Clubs</h3>
              <p>A video-first content engine across tennis, pickleball, and a $75M expansion. 11.7M cross-platform impressions in a year.</p>
            </div>
            <div class="disc">Brand /<br>Social /<br>Content /<br>Motion /<br>Photo</div>
          </div>
        </a>
        <a class="tile t-feat" href="/work/the-ninth">
          <span class="badge concept">Concept</span>
          <div class="img"><div class="ph-fill ph-bg ph-16x9"></div></div>
          <div class="meta">
            <div>
              <h3 class="h3">The Ninth</h3>
              <p>A self-initiated esports membership system built around Cloud9, brand through product, with a live AI moment-clipper at the center.</p>
            </div>
            <div class="disc">Brand /<br>UI/UX /<br>AI /<br>Motion</div>
          </div>
        </a>
      </div>
      {/* General practice-level metrics (career totals from System Master). 11.7M lives in card_A above. */}
      <div class="stat-row">
        <div class="tile t-stat"><div class="fig"><StatFigure value="10+" unit=" yrs" /></div><div class="lab">creative & marketing</div></div>
        <div class="tile t-stat"><div class="fig"><StatFigure value="20+" /></div><div class="lab">brands & organizations</div></div>
        <div class="tile t-stat"><div class="fig"><StatFigure value="75+" /></div><div class="lab">campaigns launched</div></div>
        <div class="tile t-stat"><div class="fig"><StatFigure value="10K+" /></div><div class="lab">design assets produced</div></div>
      </div>
    </div>
  </section>

  {/* WORK INDEX */}
  <section class="block" id="work">
    <SectionLabel code="02" title="Selected work" more={{ href: '/work', label: 'View all →' }} />
    <WorkIndex entries={selectedWork} />
  </section>

  {/* MODULES — the practice, documented */}
  <section class="block">
    <SectionLabel code="03" title="The practice" />
    <div class="duo">
      <a class="mod rev" id="brand" href="/brand">
        <div class="k">One System · brand</div>
        <h3 class="h2">One system, end to end.</h3>
        <p>The brand, the work, and the thinking run on the same logic: built like a system, accountable to what it does after it ships.</p>
        <span class="go">See the brand system →</span>
      </a>
      <a class="mod mod-about rev" id="about" href="/about">
        <div class="face"><Image src={headshot} alt="Pratik Mehta" width={360} format="webp" /></div>
        <div class="about-body">
          <div class="k">About</div>
          <h3 class="h2">Engineer turned creative.</h3>
          <p>I started in computer science and kept moving toward the people the work is actually for, through design, into marketing. Now I build creative, social, and performance as one connected system.</p>
          <span class="go">More about the practice →</span>
        </div>
      </a>
    </div>
  </section>

  {/* JOURNAL */}
  <section class="block" id="journal">
    <SectionLabel code="04" title="Journal" />
    <div class="jr-empty rev">
      <span class="jr-tag">[ Coming soon ]</span>
      <p>Notes on systems, brand, and AI. The first posts go up after launch.</p>
    </div>
  </section>

  {/* Hero animation: loop + pause off-screen + click-to-toggle + reduced-motion */}
  <script>
    (function () {
      var btn = document.querySelector('[data-hero-video]');
      if (!btn) return;
      var video = btn.querySelector('video');
      var chip = btn.querySelector('.hero-video-state');
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
      var userPaused = false; // explicit click choice — overrides auto-resume
      var inView = true;

      function sync() {
        var playing = !video.paused;
        btn.setAttribute('aria-pressed', String(playing));
        if (chip) chip.textContent = playing ? '❚❚ Pause' : '▶ Play';
      }
      function autoPlay() {
        if (userPaused || reduce.matches || !inView) return;
        var p = video.play();
        if (p && p.catch) p.catch(function () {});
      }

      // reduced motion: never autoplay, rest on the poster still
      if (reduce.matches) { video.removeAttribute('autoplay'); video.pause(); }

      // pause when scrolled out of view, resume when back (saves CPU/battery)
      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function (es) {
          es.forEach(function (e) {
            inView = e.isIntersecting;
            if (inView) autoPlay(); else video.pause();
          });
        }, { threshold: 0.25 }).observe(btn);
      }

      // click anywhere on the video toggles play/pause (a deliberate choice)
      btn.addEventListener('click', function () {
        if (video.paused) { userPaused = false; var p = video.play(); if (p && p.catch) p.catch(function () {}); }
        else { userPaused = true; video.pause(); }
      });

      video.addEventListener('play', sync);
      video.addEventListener('pause', sync);
      sync();
    })();
  </script>

  {/* CLOSE */}
  <section class="close" id="contact">
    <div class="rev">
      <h2 class="big close-h">Open to the right role.</h2>
      <div class="avail">Open to creative or marketing leadership roles · New York</div>
      <div class="btn-row"><a class="btn btn-p" href="/contact">Start a conversation →</a><a class="btn btn-g" href="/work">See the work →</a></div>
    </div>
  </section>
</Base>

<style>
  /* ===== SPLIT HERO ===== */
  .hero { min-height: 100vh; display: flex; align-items: center; padding: 64px 0; }
  .hero-inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 56px; align-items: center; width: 100%; }
  .hero-inner > div { display: flex; flex-direction: column; justify-content: center; }
  .hero .kick { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 26px; }
  .hero h1 { margin: 0; }
  .hero .lead { margin-top: 26px; }
  .hero .btn-row { margin-top: 36px; }
  .hero-figure { position: relative; display: flex; flex-direction: column; }
  /* square (1:1) frame hosting the brand-mark animation (public/hero) */
  .hero-figure .frame { aspect-ratio: var(--ratio-square); border: 1px solid var(--img-frame); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); }
  .hero-figure .frame img { width: 100%; height: 100%; object-fit: cover; }

  /* video is wrapped in a button so the whole surface is a click-to-pause
     target (keyboard-operable, labelled). The state chip fades in on hover
     or while paused, so the pause gesture is discoverable, not hidden. */
  .hero-video { display: block; width: 100%; height: 100%; padding: 0; border: 0; background: none; cursor: pointer; position: relative; }
  .hero-video video { display: block; width: 100%; height: 100%; object-fit: cover; }
  .hero-video-state {
    position: absolute; bottom: 12px; right: 12px;
    /* fixed box + centered label so Play/Pause swap doesn't resize/shift it */
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 84px; height: 26px; box-sizing: border-box;
    font-family: var(--font-mono); font-size: 10.5px; font-weight: 500;
    line-height: 1; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--n-50); background: rgba(11, 11, 10, .55);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    padding: 0 9px; border-radius: var(--radius-none);
    opacity: 0; transition: opacity .2s var(--ease-standard); pointer-events: none;
  }
  .hero-video:hover .hero-video-state,
  .hero-video:focus-visible .hero-video-state,
  .hero-video[aria-pressed="false"] .hero-video-state { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    /* show the poster still only; no controls affordance */
    .hero-video { cursor: default; }
    .hero-video-state { display: none; }
  }

  /* ===== BENTO — two equal feature cards + a general stat strip ===== */
  /* The feature cards teaser the work. The stat strip carries GENERAL practice
     metrics (placeholder until System Master) — not case-study-specific numbers,
     which live on each case study. Features are equal 16:9 so they crop cleanly. */
  .bento { display: flex; flex-direction: column; gap: 16px; }
  .feat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .tile { border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); overflow: hidden; position: relative; transition: border-color .2s var(--ease-standard); }
  .tile:hover { border-color: var(--border-strong); }

  .t-feat { display: flex; flex-direction: column; }
  .t-feat .img { aspect-ratio: var(--ratio-wide); overflow: hidden; }
  .t-feat .img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease-standard); }
  .t-feat:hover .img img { transform: scale(1.03); }
  .t-feat .meta { padding: 20px; display: flex; justify-content: space-between; align-items: flex-end; gap: 16px; }
  .t-feat .meta p { font-size: 13.5px; color: var(--text-secondary); margin-top: 8px; max-width: 38ch; }
  .t-feat .meta .disc { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); text-align: right; white-space: nowrap; line-height: 1.8; }

  .badge { position: absolute; top: 16px; left: 16px; z-index: 2; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 8px; border-radius: var(--radius-none); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
  .badge.client { background: rgba(255, 90, 31, .16); color: var(--accent-300); border: 1px solid rgba(255, 90, 31, .35); }
  .badge.concept { background: var(--badge-concept-bg); color: var(--badge-concept-tx); border: 1px solid var(--border-strong); }

  .t-stat { padding: 22px; display: flex; flex-direction: column; justify-content: center; gap: 10px; min-height: 132px; }
  .t-stat .fig { font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 3vw, 42px); line-height: 1; letter-spacing: -0.02em; color: var(--text); }
  .t-stat .lab { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); line-height: 1.5; max-width: 24ch; }

  /* ===== MODULES ===== */
  .duo { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .mod { border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); padding: 28px; display: flex; flex-direction: column; transition: border-color .2s var(--ease-standard); }
  .mod:hover { border-color: var(--border-strong); }
  .mod .k { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent-text); margin-bottom: 18px; }
  .mod p { font-size: 14px; color: var(--text-secondary); max-width: 46ch; margin-top: 10px; }
  .mod .go { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text); margin-top: auto; padding-top: 22px; }
  /* About module: portrait headshot shown larger and side-by-side, cropped square (in-system) instead of a tiny vertical thumb */
  /* image matches the height of the text column beside it (stretches, no fixed aspect) */
  .mod-about { flex-direction: row; align-items: stretch; gap: 24px; }
  .mod-about .face { width: 160px; border-radius: var(--radius-md); flex: none; overflow: hidden; }
  .mod-about .face img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mod-about .about-body { flex: 1; display: flex; flex-direction: column; }
  @media (max-width: 560px) {
    .mod-about { flex-direction: column; align-items: flex-start; gap: 18px; }
    .mod-about .face { width: 140px; aspect-ratio: var(--ratio-square); }
  }

  /* ===== JOURNAL ===== */
  .jr-empty { border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); padding: 48px; display: flex; flex-direction: column; gap: 14px; align-items: flex-start; }
  .jr-empty .jr-tag { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-text); }
  .jr-empty p { font-size: 18px; color: var(--text-secondary); }

  /* ===== CLOSE ===== */
  .close { padding: 110px 0; }
  .close .big { max-width: 14ch; margin-bottom: 22px; }
  .close .avail { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 34px; }

  /* ===== responsive ===== */
  @media (max-width: 1100px) {
    .hero { min-height: auto; padding: 48px 0; }
    .hero-inner { grid-template-columns: 1fr; gap: 36px; align-items: start; }
    .hero-inner > div { justify-content: flex-start; }
  }
  @media (max-width: 900px) {
    .duo { grid-template-columns: 1fr; }
    .feat-row { grid-template-columns: 1fr; }
    .stat-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .stat-row { grid-template-columns: 1fr; }
  }
</style>
