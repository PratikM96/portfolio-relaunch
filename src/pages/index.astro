---
/**
 * Home — One System portfolio.
 * Ported from _reference/mockups/home-design-v5-converged.html. Chrome (console rail,
 * footer, theme, fonts) lives in Base.astro. Repeated pieces are extracted to
 * components; hero / bento / modules / journal / close stay inline here.
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import headshot from '../assets/headshot-4x5.jpg';
import SectionLabel from '../components/SectionLabel.astro';
import DisciplineStrip from '../components/DisciplineStrip.astro';
import WorkIndex from '../components/WorkIndex.astro';
import StatFigure from '../components/StatFigure.astro';
import CloseCTA from '../components/CloseCTA.astro';

// Curated "Selected work" for the home index. The featured pair (SPORTIME + The
// Ninth) is showcased in the Bento above, so it's omitted here; the full set
// lives on /work (linked via "View all").
const SELECTED = ['dealnews', 'raa', 'agency-fiveeighty', 'level', 'wisp'];
const allWork = await getCollection('work');
const bySlug = new Map(allWork.map((e) => [e.data.slug, e]));
const selectedWork = SELECTED.map((s) => bySlug.get(s)).filter((e) => e !== undefined);

// Journal teaser — the three most recent published posts, newest first.
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
const journalPosts = (await getCollection('journal'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

---

<Base
  title="Pratik Mehta · Creative Marketing Lead"
  description="I build creative, social, and performance as one system. Creative Marketing Lead in New York, with an AI-forward workflow."
  preloadImage="/hero/home/poster.webp"
>
  {/* SPLIT HERO */}
  <section class="hero">
    <div class="hero-inner">
      <div>
        <div class="kick rev-load">Open to creative or marketing leadership roles · New York</div>
        <h1 class="rev-load page-h1">I build creative, social, and performance as <span class="signal">one system.</span></h1>
        <p class="lead rev-load">I connect the creation of creative to the marketing system that makes it perform, and own it from the idea to what it does after it ships.</p>
        <div class="btn-row rev-load"><a class="btn btn-p" href="/work">See the work →</a><a class="btn btn-g" href="/contact">Start a conversation →</a></div>
      </div>
      <figure class="hero-figure rev-load">
        {/* 1:1 brand-mark animation. Self-hosted (public/hero), webm.
            Loops, pauses off-screen + on click; reduced-motion shows the
            poster still and never autoplays. JS hook: data-hero-video. */}
        <div class="frame">
          <button class="hero-video" type="button" data-hero-video
            aria-label="Play or pause the intro animation" aria-pressed="true">
            <video
              poster="/hero/home/poster.webp"
              width="1080" height="1080"
              muted loop playsinline preload="none"
            >
              <source src="/hero/home/hero_1080.webm" type="video/webm" />
            </video>
            <span class="hero-video-state" aria-hidden="true">❚❚ Pause</span>
          </button>
        </div>
      </figure>
    </div>
  </section>

  {/* DISCIPLINES STRIP */}
  <DisciplineStrip />

  {/* BENTO — featured */}
  <section class="block" id="featured">
    <SectionLabel code="01" title="Featured" />
    <div class="bento rev">
      <div class="feat-row">
        <a class="card card--interactive t-feat" href="/work/sportime-clubs">
          <span class="badge in-house">In-house</span>
          <div class="img">
            <video class="tile-video" muted loop playsinline preload="none" data-slug="sportime-clubs" poster="/wc/sportime-clubs/poster.webp">
              <source src="/wc/sportime-clubs/card.webm" type="video/webm" />
            </video>
          </div>
          <div class="meta">
            <div>
              <h3 class="h3">SPORTIME Clubs</h3>
              <p>A video-first content engine across tennis, pickleball, and a $75M expansion. 11.7M cross-platform impressions in a year.</p>
            </div>
            <div class="disc">Brand /<br>Social /<br>Content /<br>Motion /<br>Photo</div>
          </div>
        </a>
        <a class="card card--interactive t-feat" href="/work/the-ninth">
          <span class="badge concept">Concept</span>
          <div class="img">
            <video class="tile-video" muted loop playsinline preload="none" data-slug="the-ninth" poster="/wc/the-ninth/poster.webp">
              <source src="/wc/the-ninth/card.webm" type="video/webm" />
            </video>
          </div>
          <div class="meta">
            <div>
              <h3 class="h3">The Ninth</h3>
              <p>A self-initiated esports membership system built around Cloud9, brand through product, with a live AI moment-clipper at the center.</p>
            </div>
            <div class="disc">Brand /<br>UI/UX /<br>AI /<br>Motion</div>
          </div>
        </a>
      </div>
      {/* General practice-level metrics (career totals from System Master). 11.7M lives in card_A above. */}
      <div class="stat-row">
        <div class="card card--interactive t-stat"><div class="fig"><StatFigure value="10+" unit=" yrs" /></div><div class="lab">creative & marketing</div></div>
        <div class="card card--interactive t-stat"><div class="fig"><StatFigure value="20+" /></div><div class="lab">brands, partners & organizations</div></div>
        <div class="card card--interactive t-stat"><div class="fig"><StatFigure value="75+" /></div><div class="lab">campaigns launched</div></div>
        <div class="card card--interactive t-stat"><div class="fig"><StatFigure value="10K+" /></div><div class="lab">design assets produced</div></div>
      </div>
    </div>
  </section>

  {/* WORK INDEX */}
  <section class="block" id="work">
    <SectionLabel code="02" title="Selected work" more={{ href: '/work', label: 'View all →' }} />
    <WorkIndex entries={selectedWork} />
  </section>

  {/* MODULES — the practice, documented */}
  <section class="block">
    <SectionLabel code="03" title="The practice" />
    <div class="duo">
      <a class="card card--interactive mod rev" id="brand" href="/brand">
        <div class="k">One System · brand</div>
        <h3 class="h2">One system, end to end.</h3>
        <p>The brand, the work, and the thinking run on the same logic: built like a system, accountable to what it does after it ships.</p>
        <span class="go">See the brand system →</span>
      </a>
      <a class="card card--interactive mod mod-about rev" id="about" href="/about">
        <div class="face"><Image src={headshot} alt="Pratik Mehta" width={360} format="webp" /></div>
        <div class="about-body">
          <div class="k">About</div>
          <h3 class="h2">Engineer turned creative.</h3>
          <p>I started in computer science and kept moving toward the people the work is actually for, through design into marketing. Now I build creative, social, and performance as one connected system.</p>
          <span class="go">More about the practice →</span>
        </div>
      </a>
    </div>
  </section>

  {/* JOURNAL */}
  <section class="block" id="journal">
    <SectionLabel
      code="04"
      title="Journal"
      more={journalPosts.length > 0 ? { href: '/journal', label: 'View all →' } : undefined}
    />
    {
      journalPosts.length === 0 ? (
        <div class="card jr-empty rev">
          <span class="jr-tag">[ Coming soon ]</span>
          <p>Notes on systems, brand, and AI. The first posts go up after launch.</p>
        </div>
      ) : (
        <div class="jr-list rev">
          {journalPosts.map((p) => (
            <a class="jr-row" href={`/journal/${p.id}`}>
              <div class="jr-text">
                <div class="jr-t">{p.data.title}</div>
                <div class="jr-ex">{p.data.excerpt}</div>
              </div>
              <div class="jr-m">
                {[p.data.topic, fmtDate(p.data.date), p.data.readingTime].filter(Boolean).join(' · ')}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </section>

  {/* Hero animation: loop + pause off-screen + click-to-toggle + reduced-motion */}
  <script>
    import { prefersReducedMotion } from '../scripts/motion';
    (function () {
      const btn = document.querySelector('[data-hero-video]');
      if (!btn) return;
      const video = btn.querySelector('video');
      if (!video) return;
      var chip = btn.querySelector('.hero-video-state');
      var userPaused = false; // explicit click choice — overrides auto-resume
      var inView = true;
      var ready = false; // gate playback until after load (see start() below)

      const sync = function () {
        var playing = !video.paused;
        btn.setAttribute('aria-pressed', String(playing));
        if (chip) chip.textContent = playing ? '❚❚ Pause' : '▶ Play';
      };
      const autoPlay = function () {
        if (!ready || userPaused || prefersReducedMotion() || !inView) return;
        var p = video.play(); // preload="none" → play() triggers the fetch
        if (p && p.catch) p.catch(function () {});
      };

      // Defer the animation until after load, THEN until the main thread is
      // idle. The poster (preloaded) covers the initial paint window, so the
      // ~1.1MB video stays off the critical path (LCP, Speed Index) and off
      // mobile data until the page is genuinely settled. Firing on `load`
      // alone wasn't enough: a Lighthouse mobile trace still caught the fetch
      // inside the measurement window, competing for a throttled link.
      //
      // On a metered or slow connection it never auto-starts at all — the
      // poster is the whole experience there. A click always starts it
      // regardless (the handler below calls play() directly, ungated), so the
      // animation stays reachable. Reduced motion never starts it.
      // Network Information API — Chromium-only, absent in Safari/Firefox, so
      // every read is guarded and "unknown" falls through to normal playback.
      var conn = (navigator as any).connection;
      var frugal = !!conn && (conn.saveData === true || /^((slow-)?2g|3g)$/.test(conn.effectiveType || ''));
      var idle = (window as any).requestIdleCallback || function (cb: () => void) { return setTimeout(cb, 200); };
      var start = function () { idle(function () { ready = true; autoPlay(); }, { timeout: 2000 }); };
      if (prefersReducedMotion() || frugal) { video.pause(); }
      else if (document.readyState === 'complete') start();
      else window.addEventListener('load', start, { once: true });

      // pause when scrolled out of view, resume when back (saves CPU/battery)
      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function (es) {
          es.forEach(function (e) {
            inView = e.isIntersecting;
            if (inView) autoPlay(); else video.pause();
          });
        }, { threshold: 0.25 }).observe(btn);
      }

      // click anywhere on the video toggles play/pause (a deliberate choice)
      btn.addEventListener('click', function () {
        if (video.paused) { userPaused = false; var p = video.play(); if (p && p.catch) p.catch(function () {}); }
        else { userPaused = true; video.pause(); }
      });

      video.addEventListener('play', sync);
      video.addEventListener('pause', sync);
      sync();
    })();
  </script>

  {/* CLOSE */}
  <CloseCTA id="contact" />
</Base>

<script>
  import { wireHoverCards } from '../scripts/card-video';

  // Bento featured tiles: hover-to-play card clip, snap back to poster on leave.
  // Mirrors the /work featured-pair behavior; the hero video above has its own
  // click-to-play controller and is untouched.
  wireHoverCards('.t-feat', '.tile-video');
</script>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .t-stat .fig {
    font-family: var(--t-display-font); font-weight: var(--t-display-weight); letter-spacing: var(--t-display-track);
  }
  .jr-t {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .hero .kick,
  .hero-video-state,
  .t-feat .meta .disc,
  .t-stat .lab,
  .mod .k,
  .mod .go,
  .jr-empty .jr-tag,
  .jr-m,
  .close .avail {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }


  /* ===== SPLIT HERO ===== */
  .hero { min-height: 100vh; display: flex; align-items: center; padding: var(--space-3xl) 0; }
  .hero-inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-3xl); align-items: center; width: 100%; }
  .hero-inner > div { display: flex; flex-direction: column; justify-content: center; }
  .hero .kick { font-size: 11px; text-transform: uppercase; color: var(--text-secondary); margin-bottom: var(--space-lg); }
  .hero h1 { margin: 0; }
  .hero .lead { margin-top: var(--space-lg); }
  .hero .btn-row { margin-top: var(--space-xl); }
  .hero-figure { position: relative; display: flex; flex-direction: column; }
  /* square (1:1) frame hosting the brand-mark animation (public/hero) */
  .hero-figure .frame { aspect-ratio: var(--ratio-square); border: 1px solid var(--img-frame); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); }
  .hero-figure .frame img { width: 100%; height: 100%; object-fit: cover; }

  /* video is wrapped in a button so the whole surface is a click-to-pause
     target (keyboard-operable, labelled). The state chip fades in on hover
     or while paused, so the pause gesture is discoverable, not hidden. */
  .hero-video { display: block; width: 100%; height: 100%; padding: 0; border: 0; background: none; cursor: pointer; position: relative; }
  .hero-video video { display: block; width: 100%; height: 100%; object-fit: cover; }
  .hero-video-state {
    position: absolute; bottom: 12px; right: 12px;
    /* fixed box + centered label so Play/Pause swap doesn't resize/shift it */
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 84px; height: 26px; box-sizing: border-box;
     font-size: 10.5px;
    line-height: 1; text-transform: uppercase;
    color: var(--n-50); background: rgba(11, 11, 10, .55);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    padding: 0 var(--space-xs); border-radius: var(--radius-none);
    opacity: 0; transition: opacity .2s var(--ease-standard); pointer-events: none;
  }
  .hero-video:hover .hero-video-state,
  .hero-video:focus-visible .hero-video-state,
  .hero-video[aria-pressed="false"] .hero-video-state { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    /* show the poster still only; no controls affordance */
    .hero-video { cursor: default; }
    .hero-video-state { display: none; }
  }

  /* ===== BENTO — two equal feature cards + a general stat strip ===== */
  /* The feature cards teaser the work. The stat strip carries GENERAL practice
     metrics, not case-study-specific numbers, which live on each case study.
     Features are equal 16:9 so they crop cleanly. */
  .bento { display: flex; flex-direction: column; gap: var(--space-md); }
  .feat-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
  .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-md); }
  /* surface + hover come from global .card / .card--interactive; these add only
     the shared clip/stack behaviour of the bento tiles */
  .card.t-feat, .card.t-stat { overflow: hidden; position: relative; }

  .t-feat { display: flex; flex-direction: column; }
  .t-feat .img { aspect-ratio: var(--ratio-wide); overflow: hidden; position: relative; }
  .t-feat .img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease-standard); }
  .t-feat:hover .img img { transform: scale(1.03); }
  /* hover-to-play clip over the tile cover; poster (resolved logo) shows at rest */
  .tile-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease-standard); }
  .t-feat:hover .tile-video { transform: scale(1.03); }
  .t-feat .meta { padding: var(--space-lg); display: flex; justify-content: space-between; align-items: flex-end; gap: var(--space-md); }
  .t-feat .meta p { font-size: 13.5px; color: var(--text-secondary); margin-top: var(--space-xs); max-width: 38ch; }
  .t-feat .meta .disc { font-size: 10px; text-transform: uppercase; color: var(--text-muted); text-align: right; white-space: nowrap; line-height: 1.8; }

  /* .badge / .badge.in-house / .badge.concept come from global.css */

  .t-stat { padding: var(--space-lg); display: flex; flex-direction: column; justify-content: center; gap: var(--space-sm); min-height: 132px; }
  .t-stat .fig { font-size: clamp(28px, 3vw, 42px); line-height: 1; color: var(--text); }
  .t-stat .lab { font-size: 10px; text-transform: uppercase; color: var(--text-muted); line-height: 1.5; max-width: 24ch; }

  /* ===== MODULES ===== */
  .duo { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
  /* surface + hover come from global .card / .card--interactive */
  .mod { padding: var(--space-xl); display: flex; flex-direction: column; }
  .mod .k { font-size: 10.5px; text-transform: uppercase; color: var(--accent-text); margin-bottom: var(--space-md); }
  .mod p { font-size: 14px; color: var(--text-secondary); max-width: 46ch; margin-top: var(--space-sm); }
  .mod .go { font-size: 11px; text-transform: uppercase; color: var(--text); margin-top: auto; padding-top: var(--space-lg); }
  /* About module: portrait headshot shown larger and side-by-side, cropped square (in-system) instead of a tiny vertical thumb */
  /* image matches the height of the text column beside it (stretches, no fixed aspect) */
  .mod-about { flex-direction: row; align-items: stretch; gap: var(--space-lg); }
  .mod-about .face { width: 160px; border-radius: var(--radius-md); flex: none; overflow: hidden; }
  .mod-about .face img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mod-about .about-body { flex: 1; display: flex; flex-direction: column; }
  @media (max-width: 560px) {
    .mod-about { flex-direction: column; align-items: flex-start; gap: var(--space-md); }
    .mod-about .face { width: 140px; aspect-ratio: var(--ratio-square); }
  }

  /* ===== JOURNAL ===== */
  /* surface comes from global .card */
  .jr-empty { padding: var(--space-2xl); display: flex; flex-direction: column; gap: var(--space-md); align-items: flex-start; }
  .jr-empty .jr-tag { font-size: 11px; text-transform: uppercase; color: var(--accent-text); }
  .jr-empty p { font-size: 18px; color: var(--text-secondary); }

  .jr-list { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
  .jr-row { display: grid; grid-template-columns: 1fr auto; gap: var(--space-xl); align-items: baseline; padding: var(--space-lg) 0; border-bottom: 1px solid var(--border); transition: padding-left 0.2s var(--ease-standard); }
  .jr-row:hover { padding-left: var(--space-sm); }
  .jr-t { font-size: clamp(19px, 2.2vw, 24px); color: var(--text-secondary); transition: color 0.2s var(--ease-standard); }
  .jr-row:hover .jr-t { color: var(--text); }
  .jr-ex { font-size: 14px; color: var(--text-muted); margin-top: var(--space-xs); max-width: 60ch; }
  .jr-m { font-size: 11px; text-transform: uppercase; color: var(--text-muted); white-space: nowrap; text-align: right; }
  @media (max-width: 700px) { .jr-m { display: none; } }

  /* ===== CLOSE — now the shared CloseCTA component ===== */

  /* ===== responsive ===== */
  @media (max-width: 1100px) {
    .hero { min-height: auto; padding: var(--space-2xl) 0; }
    .hero-inner { grid-template-columns: 1fr; gap: var(--space-xl); align-items: start; }
    .hero-inner > div { justify-content: flex-start; }
  }
  @media (max-width: 900px) {
    .duo { grid-template-columns: 1fr; }
    .feat-row { grid-template-columns: 1fr; }
    .stat-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .stat-row { grid-template-columns: 1fr; }
  }
</style>
