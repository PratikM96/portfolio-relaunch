---
/**
 * Contact — Pratik Mehta. Ported from _reference/mockups/contact.html.
 * Default rail + footer from Base.astro; global .btn primitives from global.css.
 * No availability dot here (the one pulsing dot lives only in the sidebar).
 *
 * Body copy is the approved mockup placeholder until Phase 4. Verified contact
 * facts: email, New York, LinkedIn (linkedin.com/in/pratikm96).
 */
import Base from '../layouts/Base.astro';

const EMAIL = 'mehtadpratik@gmail.com';
const LINKEDIN = 'https://www.linkedin.com/in/pratikm96';
---

<Base
  image="/og/default.png"
  title="Contact · Pratik Mehta"
  description="Get in touch with Pratik Mehta, Creative Marketing Lead in New York. Open to creative or marketing leadership roles."
  activeNav="contact"
>
  <section class="chero">
    <div class="page-kicker rev">[ Contact ]</div>
    <h1 class="rev page-h1">Let's build it as <span class="signal">one system.</span></h1>
    <div class="avail rev">Open to creative or marketing leadership roles · New York</div>

    <div class="cgrid rev">
      <a class="ccell" href={`mailto:${EMAIL}`}><span class="k">Email</span><span class="v">{EMAIL}</span></a>
      <a class="ccell" href={LINKEDIN} target="_blank" rel="noopener"><span class="k">LinkedIn</span><span class="v">in / pratikm96</span></a>
      <a class="ccell" href="/resume"><span class="k">Resume</span><span class="v">Read the resume →</span></a>
      <a class="ccell" href="/work"><span class="k">Work</span><span class="v">See the work →</span></a>
    </div>
  </section>
</Base>

<style>
  .chero { padding: 104px 0 96px; }
  .chero h1 { max-width: 16ch; }
  .chero .avail { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; text-transform: uppercase; color: var(--text-secondary); margin-top: 32px; }

  /* one row of four on desktop; 2-up on tablet, 1-up on mobile */
  .cgrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; margin-top: 48px; max-width: 1040px; }
  .ccell { background: var(--surface); padding: 22px; display: flex; flex-direction: column; gap: 12px; transition: background .2s var(--ease-standard); }
  .ccell:hover { background: var(--surface-raised); }
  .ccell .k { font-family: var(--font-mono); font-size: 10px; letter-spacing: .06em; text-transform: uppercase; color: var(--text-muted); }
  .ccell .v { font-family: var(--font-sans); font-weight: 600; font-size: 15.5px; color: var(--text); letter-spacing: -.01em; word-break: break-word; transition: color .2s var(--ease-standard); }
  .ccell:hover .v { color: var(--accent-text); }

  @media (max-width: 900px) { .chero { padding: 56px 0 64px; } .cgrid { grid-template-columns: repeat(2, 1fr); max-width: 620px; } }
  @media (max-width: 560px) { .cgrid { grid-template-columns: 1fr; } }
</style>
