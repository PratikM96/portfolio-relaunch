---
/**
 * About — the practice. Ported verbatim from _reference/mockups/about.html.
 * Chrome (default console rail, footer, theme, fonts) comes from Base.astro;
 * shared primitives (.block, .blabel, .signal, .btn, .prose) from global.css.
 * Only page-specific layout (hero, path, principles, tools) is scoped below.
 */
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import headshot from '../assets/headshot-4x5.jpg';
---

<Base
  image="/og/about.png"
  title="About · Pratik Mehta"
  description="Creative Marketing Lead in New York. I started in computer science and build creative, social, and performance as one system."
  activeNav="about"
>
  {/* HERO */}
  <section class="ahero">
    <div>
      <div class="page-kicker rev">[ About ] · the practice</div>
      <h1 class="rev page-h1">I came to creative through <span class="signal">code.</span></h1>
      <p class="lead rev">I started in computer science and kept following the path toward the people the work was for, through design and into marketing. The systems habit stayed with me, now pointed at things an audience actually sees.</p>
      <div class="btn-row rev"><a class="btn btn-p" href="/resume">View resume →</a><a class="btn btn-g" href="/work">See the work →</a></div>
    </div>
    <figure class="portrait rev"><Image src={headshot} alt="Pratik Mehta" width={900} format="webp" /></figure>
  </section>

  {/* THE PATH */}
  <section class="block">
    <div class="blabel"><span class="c">[ 01 ]</span><span class="t">The path</span><span class="rule"></span></div>
    <div class="path rev">
      <div class="step"><div class="yr">Foundation</div><div><h3>Engineer</h3><p>I started in computer science at NYU. Before any design or marketing, I learned to think in systems: how the parts connect, and where they break.</p></div></div>
      <div class="step"><div class="yr">The turn</div><div><h3>Design</h3><p>Leading a volunteer design team is where it clicked that I cared more about the people the work was for than the code behind it. I moved toward design.</p></div></div>
      <div class="step"><div class="yr">The anchor</div><div><h3>Marketing</h3><p>Design pulled me into marketing, because work that looks right still has to perform. I started tying the making of the creative to what it actually returned.</p></div></div>
      <div class="step"><div class="yr">Apr 2024 to present</div><div><h3>Independent practice</h3><p>Now I run an independent creative systems practice: brand, social, and performance built as one system, plus self-initiated concepts like The Ninth, Level, and WISP to push the idea further.</p></div></div>
    </div>
  </section>

  {/* HOW I WORK */}
  <section class="block">
    <div class="blabel"><span class="c">[ 02 ]</span><span class="t">How I work</span><span class="rule"></span></div>
    <div class="princ rev">
      <div class="card pcard"><div class="n">01</div><h3>One system, end to end</h3><p>I connect the creative to the marketing that makes it perform, and hold the whole arc so nothing gets lost in handoff.</p></div>
      <div class="card pcard"><div class="n">02</div><h3>Built, not briefed</h3><p>I react to built things, working prototypes and real output, not decks describing them.</p></div>
      <div class="card pcard"><div class="n">03</div><h3>Accountable to what it does</h3><p>Creative has to answer to a result. I keep the work tied to performance, not just polish.</p></div>
    </div>
  </section>

  {/* TOOLS & AI */}
  <section class="block">
    <div class="blabel"><span class="c">[ 03 ]</span><span class="t">Tools &amp; AI workflow</span><span class="rule"></span></div>
    <div class="prose rev">
      <p><strong>AI-forward across the workflow.</strong> I use AI across research, production, and iteration, to move faster and cover more of the system. It speeds the work; it does not do the thinking.</p>
    </div>
    <div class="tools rev">
      <span>Brand systems</span><span>Social &amp; content</span><span>UI/UX</span><span>Motion</span><span>Performance</span><span>Design tokens</span><span>Front-end</span><span>AI workflow</span>
    </div>
  </section>

  {/* CTA */}
  <section class="block" style="text-align:left">
    <h2 class="about-cta-h close-h">Let's build it as one system.</h2>
    <div class="about-cta-avail">Open to creative or marketing leadership roles · New York</div>
    <div class="btn-row"><a class="btn btn-p" href="/contact">Start a conversation →</a><a class="btn btn-g" href="/work">See the work →</a><a class="btn btn-g" href="/resume">View resume →</a></div>
  </section>
</Base>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .path .step h3,
  .pcard h3 {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .path .step .yr,
  .tools span,
  .about-cta-avail {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }
  .pcard .n {
    font-family: var(--t-data-font); font-weight: var(--t-data-weight); letter-spacing: var(--t-data-track);
  }


  /* hero */
  .ahero { padding: var(--space-4xl) 0 var(--space-3xl); display: grid; grid-template-columns: 1.2fr .8fr; gap: var(--space-3xl); align-items: center; }
  /* type + measure come from the shared .lead primitive in global.css */
  .ahero p { margin-top: var(--space-lg); }
  .ahero .btn-row { margin-top: var(--space-xl); }
  .portrait { border: 1px solid var(--img-frame); border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 4/5; }
  .portrait img { width: 100%; height: 100%; object-fit: cover; }

  /* .prose comes from global.css */

  /* the path */
  .path { display: flex; flex-direction: column; }
  .path .step { display: grid; grid-template-columns: 160px 1fr; gap: var(--space-xl); padding: var(--space-xl) 0; border-bottom: 1px solid var(--border); align-items: baseline; }
  .path .step:last-child { border-bottom: none; }
  .path .step .yr { font-size: 12px; text-transform: uppercase; color: var(--accent-text); }
  .path .step h3 { font-size: 22px; margin-bottom: var(--space-xs); }
  .path .step p { font-size: 14.5px; line-height: 1.6; color: var(--text-secondary); max-width: 62ch; }

  /* principles */
  .princ { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
  /* surface comes from global .card */
  .pcard { padding: var(--space-xl); min-height: 200px; display: flex; flex-direction: column; }
  .pcard .n { font-size: 11px; color: var(--text-muted); }
  .pcard h3 { font-size: 20px; margin: auto 0 var(--space-sm); }
  .pcard p { font-size: 13.5px; line-height: 1.55; color: var(--text-secondary); }

  /* tools */
  .tools { display: flex; flex-wrap: wrap; gap: var(--space-xs); margin-top: var(--space-lg); }
  .tools span { font-size: 11px; text-transform: uppercase; color: var(--text-secondary); border: 1px solid var(--border-strong); border-radius: var(--radius-full); padding: var(--space-xs) var(--space-sm); }

  /* cta */
  .about-cta-h { max-width: 16ch; margin-bottom: var(--space-lg); }
  .about-cta-avail { font-size: 11px; text-transform: uppercase; color: var(--text-secondary); margin-bottom: var(--space-xl); }

  @media (max-width: 1000px) {
    .ahero { grid-template-columns: 1fr; }
    .ahero .portrait { max-width: 340px; }
    .princ { grid-template-columns: 1fr; }
    .path .step { grid-template-columns: 1fr; gap: var(--space-xs); }
  }
  @media (max-width: 900px) {
    .ahero { padding: var(--space-3xl) 0 0; }
  }
</style>
