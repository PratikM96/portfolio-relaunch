---
/**
 * /work/[slug] — the single case-study route, rendered from the `work` content
 * collection. One template serves both the client and concept variants: copy
 * and structure come entirely from the entry data, so SPORTIME (client) and
 * The Ninth (concept) render identically to the hand-built pages they replace.
 *
 * Proof is one uniform ProofBox for every entry (no metric-vs-scope split); the
 * guardrail is simply "at least one proof figure". The only type-driven bits left
 * are cosmetic: the hero badge class and the rail Type line. The optional
 * EmbeddedDemo renders whenever `demo` is present.
 */
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import CaseSectionHead from '../../components/CaseSectionHead.astro';
import Scoreboard from '../../components/Scoreboard.astro';
import MarginRail from '../../components/MarginRail.astro';
import SysFlow from '../../components/SysFlow.astro';
import Decisions from '../../components/Decisions.astro';
import OutputGrid from '../../components/OutputGrid.astro';
import ProofBox from '../../components/ProofBox.astro';
import EmbeddedDemo from '../../components/EmbeddedDemo.astro';

export const getStaticPaths = (async () => {
  // Same order as the /work index (featured first, then title) so the footer
  // "next case study" walks the work page in order and loops back to the first.
  const all = (await getCollection('work')).sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return a.data.title.localeCompare(b.data.title);
  });
  return all.map((entry, i) => {
    const nx = all[(i + 1) % all.length].data;
    return {
      params: { slug: entry.data.slug },
      props: { entry, nextEntry: { type: nx.type, title: nx.title, slug: nx.slug } },
    };
  });
}) satisfies GetStaticPaths;

const { entry, nextEntry } = Astro.props;
const d = entry.data;
// Footer "next" is computed from the work-page order, not the entry frontmatter.
const csNext = {
  kicker: `Next case study · ${nextEntry.type === 'client' ? 'Client' : 'Concept'}`,
  title: nextEntry.title,
  href: `/work/${nextEntry.slug}`,
};
const isClient = d.type === 'client';

// Hero video (optional): files are convention-located by slug, so a case study
// opts in with `heroVideo: true` and drops the three files in /hero/<slug>/.
// See docs/hero-pipeline.md for the encode recipe and naming contract.
const heroVideo = d.heroVideo
  ? {
      webm: `/hero/${d.slug}/hero_1080.webm`,
      mp4: `/hero/${d.slug}/hero_1080.mp4`,
      poster: `/hero/${d.slug}/poster.webp`,
    }
  : null;

// Output gallery: prefer the typed `blocks` model; fall back to legacy `tiles`.
// The whole section is optional — an entry with neither (e.g. frc, whose only
// asset is its hero film) drops the §Output section and its rail entry, and the
// spine renumbers so there's no gap.
const outputBlocks = d.output?.blocks;
const outputTiles = d.output?.tiles?.map((t) => ({
  wide: t.span === 'wide',
  img: t.img,
  alt: t.alt,
  ph: t.ph,
  caption: t.caption,
}));
const hasOutput = !!(outputBlocks?.length || outputTiles?.length);
// Concepts carry no output stills — their only §Output content is the live-demo
// launcher. The section (and its rail entry) appears whenever there are output
// assets OR a demo, and the OutputGrid itself renders only when assets exist.
const hasDemo = !!d.demo;
const hasOutputSection = hasOutput || hasDemo;
// Hero cover wall: shown only for a real cover image or hero video. Concepts have
// neither, so the empty placeholder wall (16:9 box + caption) is dropped for them.
const showHeroWall = isClient || !!heroVideo || !!d.cover;

// Rail (case-study variant) — spine numbered dynamically so Output can drop out.
const spine = ['problem', 'system', 'decisions', ...(hasOutputSection ? ['output'] : []), 'proof', 'reflection'];
const no = (id: string) => String(spine.indexOf(id) + 1).padStart(2, '0');
const spineLabel: Record<string, string> = {
  problem: 'Problem', system: 'System', decisions: 'Decisions', output: 'Output', proof: 'Proof',
};
const sections = spine
  .filter((id) => id !== 'reflection')
  .map((id) => ({ ix: no(id), label: spineLabel[id], href: `#${id}` }));
// A year range (more than one 4-digit year) pluralizes the rail label.
const isYearRange = (d.year.match(/\d{4}/g)?.length ?? 0) > 1;
const scoreboard = [
  { k: 'Type', v: isClient ? 'Client' : 'Concept · self-initiated', client: isClient },
  { k: 'Role', v: d.role },
  { k: isYearRange ? 'Years' : 'Year', v: d.year },
];

const pageTitle = isClient
  ? `${d.title} · Case study · Pratik Mehta`
  : `${d.title} · Case study · concept · Pratik Mehta`;

// Structured data — CreativeWork + breadcrumb (author/publisher reference the site graph in Base).
const origin = Astro.site ? Astro.site.origin : 'https://mehtapratik.com';
const workUrl = `${origin}/work/${d.slug}`;
const schema = [
  {
    '@type': 'CreativeWork',
    '@id': `${workUrl}#work`,
    name: d.title,
    headline: d.title,
    description: d.description,
    url: workUrl,
    image: `${origin}/og/${d.slug}.png`,
    author: { '@id': `${origin}/#pratik` },
    creator: { '@id': `${origin}/#pratik` },
    dateCreated: d.year.match(/\d{4}/)?.[0] ?? d.year,
    keywords: d.disciplines.join(', '),
    isPartOf: { '@id': `${origin}/#website` },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${origin}/` },
      { '@type': 'ListItem', position: 2, name: 'Work', item: `${origin}/work` },
      { '@type': 'ListItem', position: 3, name: d.title },
    ],
  },
];

---

<Base
  variant="case-study"
  image={`/og/${d.slug}.png`}
  ogType="article"
  schema={schema}
  title={pageTitle}
  description={d.description}
  sections={sections}
  scoreboard={scoreboard}
  back={{ href: '/work', label: '← Index · all work' }}
>
  {/* SCOREBOARD HERO */}
  <header class="cs-hero">
    <span class:list={['badge', isClient ? 'client' : 'concept', 'rev']}>{d.badge}</span>
    <h1 class="rev">{d.title}</h1>
    <p class="descr rev">{d.lede}</p>
    {d.disclosure && <p class="cs-disclosure rev">{d.disclosure}</p>}
    <Scoreboard cells={d.hero} />
    {showHeroWall && (heroVideo ? (
      <div class="cs-wall rev" data-cs-video>
        <video
          poster={heroVideo.poster}
          width="1920" height="1080"
          playsinline preload="none" aria-label={d.coverAlt}
        >
          <source src={heroVideo.webm} type="video/webm" />
          <source src={heroVideo.mp4} type="video/mp4" />
        </video>
        <button class="cs-video-play" type="button" aria-label={`Play the ${d.title} video`}>
          <span class="tri" aria-hidden="true"></span>
        </button>
        <span class="cap">{d.coverCaption}</span>
      </div>
    ) : (
      <div class="cs-wall rev">
        {d.cover ? <img src={d.cover} alt={d.coverAlt} /> : <div class="ph-fill ph-bg ph-16x9" />}
        <span class="cap">{d.coverCaption}</span>
      </div>
    ))}
  </header>

  {/* PROBLEM */}
  <section class="cs-sec" id="problem">
    <CaseSectionHead no={no('problem')} title="Problem" />
    <div class="cs-body rev">
      <div class="cs-main prose">
        {d.problem.prose.map((p) => (
          <p>{p.lead ? (<><strong>{p.lead}</strong>{' '}{p.text}</>) : p.text}</p>
        ))}
      </div>
      <MarginRail modules={d.problem.margin} />
    </div>
  </section>

  {/* SYSTEM */}
  <section class="cs-sec" id="system">
    <CaseSectionHead no={no('system')} title="System" />
    <div class="cs-body rev" style="margin-bottom:48px">
      <div class="cs-main prose">
        {d.system.prose.map((p) => (
          <p>{p.lead ? (<><strong>{p.lead}</strong>{' '}{p.text}</>) : p.text}</p>
        ))}
      </div>
      <MarginRail modules={d.system.margin} />
    </div>
    <SysFlow steps={d.system.steps} />
  </section>

  {/* DECISIONS */}
  <section class="cs-sec" id="decisions">
    <CaseSectionHead no={no('decisions')} title="Decisions" />
    <div class="cs-body rev" style="margin-bottom:40px">
      <div class="cs-main prose">
        {d.decisions.prose.map((p) => (
          <p>{p.lead ? (<><strong>{p.lead}</strong>{' '}{p.text}</>) : p.text}</p>
        ))}
      </div>
      <MarginRail modules={d.decisions.margin} />
    </div>
    <Decisions decisions={d.decisions.items} />
  </section>

  {/* OUTPUT (optional — omitted when an entry has neither output assets nor a
      demo). Concepts render this section with only the live-demo launcher. */}
  {hasOutputSection && (
    <section class="cs-sec" id="output">
      <CaseSectionHead no={no('output')} title="Output" />
      {hasOutput && (
        <OutputGrid slug={d.slug} blocks={outputBlocks} tiles={outputTiles} note={d.output?.note} />
      )}
      {d.demo && (
        <EmbeddedDemo
          heading={d.demo.heading}
          tabs={d.demo.tabs}
          openHref={`/concepts/${d.demo.project}/`}
          foot={d.demo.foot}
          alt={d.demo.alt}
        />
      )}
    </section>
  )}

  {/* PROOF */}
  <section class="cs-sec" id="proof">
    <CaseSectionHead no={no('proof')} title="Proof" />
    <ProofBox figures={d.proof.figures} note={d.proof.note} />
  </section>

  {/* REFLECTION + NEXT */}
  <section class="cs-sec">
    <CaseSectionHead no={no('reflection')} title="Reflection" />
    <div class="cs-body rev">
      <div class="cs-main sb-reflect">
        {d.reflection.prose.map((p) => (
          <p>{p.lead ? (<><strong>{p.lead}</strong>{' '}{p.text}</>) : p.text}</p>
        ))}
      </div>
      <MarginRail modules={d.reflection.margin} />
    </div>
    <div class="cs-next">
      <a href={csNext.href}>
        <div><div class="k">{csNext.kicker}</div><div class="t">{csNext.title}</div></div>
        <div class="arrow">→</div>
      </a>
    </div>
  </section>
</Base>

<style>
  /* ===== SCOREBOARD HERO ===== */
  .cs-hero { padding: 96px 0 56px; }
  .badge { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; padding: 5px 10px; border-radius: var(--radius-none); display: inline-block; }
  .badge.client { background: rgba(255, 90, 31, .14); color: var(--accent-text); border: 1px solid rgba(255, 90, 31, .4); }
  /* concept badge: neutral, bordered — no orange */
  .badge.concept { background: var(--badge-concept-bg); color: var(--badge-concept-tx); border: 1px solid var(--border-strong); }
  .cs-hero h1 { font-family: var(--font-display); font-weight: 700; font-size: clamp(44px, 6.5vw, 86px); line-height: 0.95; letter-spacing: -0.035em; margin: 22px 0 0; }
  .cs-hero .descr { font-size: 20px; line-height: 1.5; color: var(--text-secondary); max-width: 54ch; margin-top: 26px; }
  /* non-affiliation disclosure — a visible bordered notice, not a footnote */
  .cs-disclosure { margin-top: 24px; padding: 11px 16px; border: 1px solid var(--border-strong); border-left: 2px solid var(--accent-fill); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 11.5px; line-height: 1.5; letter-spacing: 0.02em; color: var(--text-secondary); max-width: 64ch; }
  .cs-wall { position: relative; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--img-frame); margin-top: 48px; aspect-ratio: var(--ratio-wide); background: var(--surface); }
  .cs-wall img,
  .cs-wall video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cs-wall .cap { position: absolute; left: 16px; bottom: 14px; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; background: rgba(11, 11, 10, .55); backdrop-filter: blur(6px); padding: 5px 10px; border-radius: var(--radius-none); }

  /* click-to-play hero video: poster + centered play button until first play,
     then native controls take over. Has audio, so it never autoplays. */
  .cs-video-play { position: absolute; inset: 0; width: 100%; height: 100%; display: grid; place-items: center; border: 0; background: rgba(11, 11, 10, .28); cursor: pointer; transition: background .25s var(--ease-standard); }
  .cs-video-play:hover { background: rgba(11, 11, 10, .16); }
  .cs-video-play::before { content: ""; position: absolute; width: 78px; height: 78px; border-radius: var(--radius-full); background: #fff; box-shadow: 0 8px 28px rgba(0, 0, 0, .34); transition: transform .25s var(--ease-standard); }
  .cs-video-play:hover::before { transform: scale(1.06); }
  .cs-video-play .tri { position: relative; z-index: 1; width: 0; height: 0; border-style: solid; border-width: 13px 0 13px 22px; border-color: transparent transparent transparent #0b0b0a; margin-left: 6px; }
  .cs-wall.is-playing .cs-video-play, .cs-wall.is-playing .cap { display: none; }

  /* ===== SECTIONS / PROSE / BODY ===== */
  .cs-sec { padding: 96px 0; }
  .prose { max-width: 68ch; }
  .prose p { font-size: 17px; line-height: 1.66; color: var(--text-secondary); margin-bottom: 18px; }
  .prose p strong { color: var(--text); font-weight: 600; }
  .cs-body { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 56px; align-items: start; }
  .cs-main { max-width: 68ch; }

  /* ===== REFLECTION + NEXT ===== */
  .sb-reflect { max-width: 64ch; }
  .sb-reflect p { font-size: 17px; line-height: 1.66; color: var(--text-secondary); }
  .cs-next { border-top: 1px solid var(--border); margin-top: 72px; }
  .cs-next a { display: flex; align-items: center; justify-content: space-between; padding: 48px 0; gap: 24px; transition: padding-left .25s var(--ease-standard); }
  .cs-next a:hover { padding-left: 12px; }
  .cs-next .k { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); }
  .cs-next .t { font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 4vw, 46px); letter-spacing: -0.03em; line-height: 1; margin-top: 10px; }
  .cs-next .arrow { font-family: var(--font-display); font-size: 34px; color: var(--accent-text); }

  /* ===== responsive ===== */
  @media (max-width: 1100px) { .cs-body { grid-template-columns: 1fr; gap: 32px; } }
  @media (max-width: 900px) { .cs-hero { padding: 64px 0 40px; } }
</style>

<script>
  // Click-to-play hero video: first click plays with sound and hands off to the
  // browser's native controls. Re-shows the play overlay if it ends or is paused.
  document.querySelectorAll('[data-cs-video]').forEach((wall) => {
    const video = wall.querySelector('video');
    const btn = wall.querySelector('.cs-video-play');
    if (!video || !btn) return;
    btn.addEventListener('click', () => {
      video.controls = true;
      wall.classList.add('is-playing');
      video.play();
    });
    video.addEventListener('ended', () => wall.classList.remove('is-playing'));
  });
</script>
