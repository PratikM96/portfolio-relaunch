---
/**
 * /work/[slug] — the single case-study route, rendered from the `work` content
 * collection. One template serves every engagement type: copy and structure come
 * entirely from the entry data, so SPORTIME (in-house), RAA (agency), and The
 * Ninth (concept) all render from the same code path.
 *
 * Proof is one uniform ProofBox for every entry (no metric-vs-scope split); the
 * guardrail is simply "at least one proof figure". The only type-driven bits left
 * are cosmetic: the hero badge class and the rail Type line. The optional
 * EmbeddedDemo renders whenever `demo` is present.
 */
import { getCollection } from 'astro:content';
import type { GetStaticPaths, ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import CaseSectionHead from '../../components/CaseSectionHead.astro';
import Scoreboard from '../../components/Scoreboard.astro';
import ProseSection from '../../components/ProseSection.astro';
import SysFlow from '../../components/SysFlow.astro';
import Decisions from '../../components/Decisions.astro';
import OutputGrid from '../../components/OutputGrid.astro';
import ProofBox from '../../components/ProofBox.astro';
import EmbeddedDemo from '../../components/EmbeddedDemo.astro';
import { TYPE_LABEL, TYPE_SCOREBOARD, isConceptType } from '../../lib/work-type';

export const getStaticPaths = (async () => {
  // Same order as the /work index (featured first, then title) so the footer
  // "next case study" walks the work page in order and loops back to the first.
  const all = (await getCollection('work')).sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return a.data.title.localeCompare(b.data.title);
  });
  return all.map((entry, i) => {
    const nx = all[(i + 1) % all.length].data;
    return {
      params: { slug: entry.data.slug },
      props: { entry, nextEntry: { type: nx.type, title: nx.title, slug: nx.slug } },
    };
  });
}) satisfies GetStaticPaths;

const { entry, nextEntry } = Astro.props;
const d = entry.data;
// Footer "next" is computed from the work-page order, not the entry frontmatter.
const csNext = {
  kicker: `Next case study · ${TYPE_LABEL[nextEntry.type]}`,
  title: nextEntry.title,
  href: `/work/${nextEntry.slug}`,
};
const isConcept = isConceptType(d.type);

// Hero video (optional): files are convention-located by slug, so a case study
// opts in with `heroVideo: true` and drops the three files in /hero/<slug>/.
// See docs/hero-pipeline.md for the encode recipe and naming contract.
// The hero POSTER goes through Astro's image pipeline (src/assets/hero/<slug>/),
// not public/, because it is the LCP element on every case study that has one:
// the pipeline gives it responsive widths, a content-hashed URL and intrinsic
// dimensions. Only the video itself, which the pipeline can't process, stays in
// public/hero/<slug>/. See docs/hero-pipeline.md.
const posters = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/hero/*/poster.webp',
  { eager: true },
);
const heroPoster = posters[`../../assets/hero/${d.slug}/poster.webp`]?.default;

const heroVideo = d.heroVideo ? { webm: `/hero/${d.slug}/hero_1080.webm` } : null;
if (heroVideo && !heroPoster) {
  throw new Error(`heroVideo is set for "${d.slug}" but src/assets/hero/${d.slug}/poster.webp is missing`);
}

// Output gallery: the typed `blocks` model. The section is optional — an entry
// with no output (e.g. frc, whose only asset is its hero film) drops the §Output
// section and its rail entry, and the spine renumbers so there's no gap.
const outputBlocks = d.output?.blocks;
const hasOutput = !!outputBlocks?.length;
// Concepts carry no output stills — their only §Output content is the live-demo
// launcher. The section (and its rail entry) appears whenever there are output
// assets OR a demo, and the OutputGrid itself renders only when assets exist.
const hasDemo = !!d.demo;
const hasOutputSection = hasOutput || hasDemo;

// Rail (case-study variant) — spine numbered dynamically so Output can drop out.
const spine = ['problem', 'system', 'decisions', ...(hasOutputSection ? ['output'] : []), 'proof', 'reflection'];
const no = (id: string) => String(spine.indexOf(id) + 1).padStart(2, '0');
const spineLabel: Record<string, string> = {
  problem: 'Problem', system: 'System', decisions: 'Decisions', output: 'Output', proof: 'Proof',
};
const sections = spine
  .filter((id) => id !== 'reflection')
  .map((id) => ({ ix: no(id), label: spineLabel[id], href: `#${id}` }));
// A year range (more than one 4-digit year) pluralizes the rail label.
const isYearRange = (d.year.match(/\d{4}/g)?.length ?? 0) > 1;
const scoreboard = [
  { k: 'Type', v: TYPE_SCOREBOARD[d.type], accent: !isConcept },
  { k: 'Role', v: d.role },
  { k: isYearRange ? 'Years' : 'Year', v: d.year },
];

const pageTitle = isConcept
  ? `${d.title} · Case study · concept · Pratik Mehta`
  : `${d.title} · Case study · Pratik Mehta`;

// Structured data — CreativeWork + breadcrumb (author/publisher reference the site graph in Base).
const origin = Astro.site ? Astro.site.origin : 'https://mehtapratik.com';
const workUrl = `${origin}/work/${d.slug}`;
const schema = [
  {
    '@type': 'CreativeWork',
    '@id': `${workUrl}#work`,
    name: d.title,
    headline: d.title,
    description: d.description,
    url: workUrl,
    image: `${origin}/og/${d.slug}.png`,
    author: { '@id': `${origin}/#pratik` },
    creator: { '@id': `${origin}/#pratik` },
    dateCreated: d.year.match(/\d{4}/)?.[0] ?? d.year,
    keywords: d.disciplines.join(', '),
    isPartOf: { '@id': `${origin}/#website` },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${origin}/` },
      { '@type': 'ListItem', position: 2, name: 'Work', item: `${origin}/work` },
      { '@type': 'ListItem', position: 3, name: d.title },
    ],
  },
];

---

<Base
  variant="case-study"
  image={`/og/${d.slug}.png`}
  ogType="article"
  schema={schema}
  title={pageTitle}
  description={d.description}
  sections={sections}
  scoreboard={scoreboard}
  back={{ href: '/work', label: '← Index · all work' }}
>
  {/* SCOREBOARD HERO */}
  <header class="cs-hero">
    <span class:list={['badge', 'badge-lg', d.type, 'rev-load']}>{d.badge}</span>
    <h1 class="rev-load">{d.title}</h1>
    <p class="descr rev-load">{d.lede}</p>
    {d.disclosure && <p class="cs-disclosure rev-load">{d.disclosure}</p>}
    <Scoreboard cells={d.hero} />
    {heroVideo && heroPoster && (
      <div class="cs-wall rev-load" data-cs-video>
        {/* The poster is a real <img>, not the video's `poster` attribute, so it
            gets a responsive srcset. It is the LCP element, hence eager +
            high priority. `.is-playing` hides it once playback starts. */}
        <Image
          class="cs-poster"
          src={heroPoster}
          alt={d.coverAlt ?? ''}
          widths={[480, 800, 1280, 1920]}
          sizes="(max-width: 900px) 100vw, (max-width: 1400px) 70vw, 1100px"
          loading="eager"
          fetchpriority="high"
        />
        <video
          width="1920" height="1080"
          playsinline preload="none" aria-label={d.coverAlt}
        >
          <source src={heroVideo.webm} type="video/webm" />
        </video>
        <button class="cs-video-play" type="button" aria-label={`Play the ${d.title} video`}>
          <span class="tri" aria-hidden="true"></span>
        </button>
        <span class="cap">{d.coverCaption}</span>
      </div>
    )}
  </header>

  {/* PROBLEM */}
  <section class="cs-sec" id="problem">
    <CaseSectionHead no={no('problem')} title="Problem" />
    <ProseSection prose={d.problem.prose} margin={d.problem.margin} />
  </section>

  {/* SYSTEM */}
  <section class="cs-sec" id="system">
    <CaseSectionHead no={no('system')} title="System" />
    <ProseSection prose={d.system.prose} margin={d.system.margin} gap />
    <SysFlow steps={d.system.steps} />
  </section>

  {/* DECISIONS */}
  <section class="cs-sec" id="decisions">
    <CaseSectionHead no={no('decisions')} title="Decisions" />
    <ProseSection prose={d.decisions.prose} margin={d.decisions.margin} gap />
    <Decisions decisions={d.decisions.items} />
  </section>

  {/* OUTPUT (optional — omitted when an entry has neither output assets nor a
      demo). Concepts render this section with only the live-demo launcher. */}
  {hasOutputSection && (
    <section class="cs-sec" id="output">
      <CaseSectionHead no={no('output')} title="Output" />
      {hasOutput && (
        <OutputGrid slug={d.slug} blocks={outputBlocks} note={d.output?.note} />
      )}
      {d.demo && (
        <EmbeddedDemo
          heading={d.demo.heading}
          tabs={d.demo.tabs}
          openHref={`/concepts/${d.demo.project}/`}
          foot={d.demo.foot}
        />
      )}
    </section>
  )}

  {/* PROOF */}
  <section class="cs-sec" id="proof">
    <CaseSectionHead no={no('proof')} title="Proof" />
    <ProofBox figures={d.proof.figures} note={d.proof.note} />
  </section>

  {/* REFLECTION + NEXT */}
  <section class="cs-sec">
    <CaseSectionHead no={no('reflection')} title="Reflection" />
    <ProseSection prose={d.reflection.prose} margin={d.reflection.margin} narrow />
    <div class="cs-next">
      <a href={csNext.href}>
        <div><div class="k">{csNext.kicker}</div><div class="t">{csNext.title}</div></div>
        <div class="arrow">→</div>
      </a>
    </div>
  </section>
</Base>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .cs-hero h1,
  .cs-next .t {
    font-family: var(--t-display-font); font-weight: var(--t-display-weight); letter-spacing: var(--t-display-track);
  }
  .cs-wall .cap,
  .cs-next .k {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }
  .cs-disclosure {
    font-family: var(--t-data-font); font-weight: var(--t-data-weight); letter-spacing: var(--t-data-track);
  }


  /* ===== SCOREBOARD HERO ===== */
  .cs-hero { padding: var(--space-4xl) 0 var(--space-3xl); }
  /* .badge / .badge-lg / in-house / agency / concept come from global.css */
  .cs-hero h1 { font-size: clamp(44px, 6.5vw, 86px); line-height: 0.95; margin: var(--space-lg) 0 0; }
  .cs-hero .descr { font-size: 20px; line-height: 1.5; color: var(--text-secondary); max-width: 54ch; margin-top: var(--space-lg); }
  /* non-affiliation disclosure — a visible bordered notice, not a footnote */
  .cs-disclosure { margin-top: var(--space-lg); padding: var(--space-sm) var(--space-md); border: 1px solid var(--border-strong); border-left: 2px solid var(--accent-fill); border-radius: var(--radius-sm); font-size: 11.5px; line-height: 1.5; color: var(--text-secondary); max-width: 64ch; }
  .cs-wall { position: relative; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--img-frame); margin-top: var(--space-2xl); aspect-ratio: var(--ratio-wide); background: var(--surface); }
  .cs-wall video { width: 100%; height: 100%; object-fit: cover; display: block; }
  /* the poster sits under the video and is removed once playback starts */
  .cs-wall :global(.cs-poster) { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .cs-wall.is-playing :global(.cs-poster) { display: none; }
  .cs-wall .cap { position: absolute; left: 16px; bottom: 14px; font-size: 10.5px; text-transform: uppercase; color: #fff; background: rgba(11, 11, 10, .55); backdrop-filter: blur(6px); padding: var(--space-2xs) var(--space-sm); border-radius: var(--radius-none); }

  /* click-to-play hero video: poster + centered play button until first play,
     then native controls take over. Has audio, so it never autoplays. */
  .cs-video-play { position: absolute; inset: 0; width: 100%; height: 100%; display: grid; place-items: center; border: 0; background: rgba(11, 11, 10, .28); cursor: pointer; transition: background .25s var(--ease-standard); }
  .cs-video-play:hover { background: rgba(11, 11, 10, .16); }
  .cs-video-play::before { content: ""; position: absolute; width: 78px; height: 78px; border-radius: var(--radius-full); background: #fff; box-shadow: 0 8px 28px rgba(0, 0, 0, .34); transition: transform .25s var(--ease-standard); }
  .cs-video-play:hover::before { transform: scale(1.06); }
  .cs-video-play .tri { position: relative; z-index: 1; width: 0; height: 0; border-style: solid; border-width: 13px 0 13px 22px; border-color: transparent transparent transparent #0b0b0a; margin-left: var(--space-xs); }
  .cs-wall.is-playing .cs-video-play, .cs-wall.is-playing .cap { display: none; }

  /* ===== SECTIONS / PROSE / BODY ===== */
  .cs-sec { padding: var(--space-4xl) 0; }
  /* .prose comes from global.css */
  /* ===== REFLECTION + NEXT ===== */
  .cs-next { border-top: 1px solid var(--border); margin-top: var(--space-3xl); }
  .cs-next a { display: flex; align-items: center; justify-content: space-between; padding: var(--space-2xl) 0; gap: var(--space-lg); transition: padding-left .25s var(--ease-standard); }
  .cs-next a:hover { padding-left: var(--space-sm); }
  .cs-next .k { font-size: 11px; text-transform: uppercase; color: var(--text-muted); }
  .cs-next .t { font-size: clamp(28px, 4vw, 46px); line-height: 1; margin-top: var(--space-sm); }
  /* Not a type tier: renders a single → glyph, so it takes the display family for
     the glyph shape only and has no weight/tracking to inherit. */
  .cs-next .arrow { font-family: var(--font-display); font-size: 34px; color: var(--accent-text); }

  /* ===== responsive ===== */
  @media (max-width: 900px) { .cs-hero { padding: var(--space-3xl) 0 var(--space-2xl); } }
</style>

<script>
  import { wireClickToPlay } from '../../scripts/motion';

  // Click-to-play hero video: first click plays with sound and hands off to the
  // browser's native controls. Re-shows the play overlay when the clip ends.
  document.querySelectorAll('[data-cs-video]').forEach((wall) => {
    const video = wall.querySelector('video');
    const btn = wall.querySelector('.cs-video-play');
    if (video && btn) wireClickToPlay(wall, video, btn);
  });
</script>
