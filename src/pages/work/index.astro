---
/**
 * /work — the full work index. Ported from _reference/work.html (page head,
 * featured pair, filter bar, index + sticky preview), but driven by the `work`
 * content collection rather than hardcoded rows, so it reflects the real case
 * studies and links straight to /work/[slug]. Nothing is invented: the project
 * count and year range derive from the collection.
 *
 * Chrome (default rail, footer, theme, fonts, reveal-on-scroll) is from
 * Base.astro / global.css; only the page-specific layout is scoped below.
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('work')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return a.data.title.localeCompare(b.data.title);
});

// Index views show the earliest year of a range; the kicker count + range derive
// from the collection so the page never overstates how much work exists.
const earliestYear = (y: string) => y.match(/\d{4}/g)?.at(0) ?? y;
const allYears = entries.flatMap((e) => e.data.year.match(/\d{4}/g) ?? []).sort();
const yearRange =
  allYears.length === 0
    ? ''
    : allYears[0] === allYears.at(-1)
      ? allYears[0]
      : `${allYears[0]}—${allYears.at(-1)}`;
const count = entries.length;

// Consolidated discipline filters (6 buckets). A project matches a bucket if any
// of its raw disciplines is a member of that bucket.
const buckets = [
  { label: 'Brand', token: 'brand', members: ['Brand', 'Strategy', 'Leadership'] },
  { label: 'Social & Content', token: 'social', members: ['Social', 'Content', 'Paid'] },
  { label: 'UI/UX', token: 'uiux', members: ['UI/UX', 'Product'] },
  { label: 'Motion', token: 'motion', members: ['Motion', 'Video', 'Broadcast'] },
  { label: 'AI', token: 'ai', members: ['AI'] },
  { label: 'Production', token: 'production', members: ['Print', 'Environmental', 'Photo', 'Photography', 'Event', 'Digital', 'Design'] },
];
const bucketsFor = (disc: string[]) => buckets.filter((b) => disc.some((d) => b.members.includes(d)));

const projects = entries.map((e, i) => ({
  n: String(i + 1).padStart(2, '0'),
  name: e.data.title,
  type: e.data.type,
  disc: e.data.disciplines.slice(0, 2).join(' · '),
  discLines: e.data.disciplines.slice(0, 3),
  year: earliestYear(e.data.year),
  href: `/work/${e.data.slug}`,
  cover: e.data.cover,
  lede: e.data.lede,
  tags: [e.data.type, ...bucketsFor(e.data.disciplines).map((b) => b.token)].join(' '),
  featured: e.data.featured,
}));

const featured = projects.filter((p) => p.featured);
const first = projects[0]!;
---

<Base title="Work · Pratik Mehta" description="Client and concept, filterable by type and discipline. Each one opens to a full case study." activeNav="work">
  <header class="phead">
    <div class="k">[ Work ] · {count} {count === 1 ? 'project' : 'projects'} · {yearRange}</div>
    <h1 class="rev">The work,<br />as <span class="signal">one index.</span></h1>
    <p class="rev">Client and concept, filterable by type and discipline. Pick the two or three that answer your question. Each one opens to a full case study.</p>
  </header>

  {/* featured pair */}
  <section class="feat rev">
    {featured.map((p) => (
      <a class="fcard" href={p.href}>
        <span class:list={['badge', p.type === 'client' ? 'client' : 'concept']}>{p.type === 'client' ? 'Client' : 'Concept'}</span>
        <div class="im"><img src={p.cover} alt={p.name} /></div>
        <div class="meta">
          <div>
            <h3>{p.name}</h3>
            <span class="yr">{p.year}</span>
            <p>{p.lede}</p>
          </div>
          <div class="disc">
            {p.discLines.map((d, i) => (
              <Fragment>{i > 0 && <br />}{d}{i < p.discLines.length - 1 ? ' /' : ''}</Fragment>
            ))}
          </div>
        </div>
      </a>
    ))}
  </section>

  {/* filters */}
  <div class="filters" id="filters">
    <span class="fl-k">Filter</span>
    <button class="on" data-f="all">All</button>
    <span class="div"></span>
    <button data-f="client">Client</button>
    <button data-f="concept">Concept</button>
    <span class="div"></span>
    {buckets.map((b) => (
      <button data-f={b.token}>{b.label}</button>
    ))}
  </div>

  {/* index + preview */}
  <div class="index-wrap">
    <div class="idx" id="idx">
      <div class="idx-head"><span>#</span><span>Project</span><span>Discipline</span><span>Year</span></div>
      {projects.map((p, i) => (
        <a
          class:list={['idx-row', i === 0 && 'active']}
          href={p.href}
          data-tags={p.tags}
          data-img={p.cover}
          data-t={p.name}
          data-d={p.lede}
        >
          <span class="ix">{p.n}</span>
          <span class="nm">
            <b>{p.name}</b>
            <span class:list={['ty', p.type === 'client' && 'client']}>{p.type === 'client' ? 'Client' : 'Concept'}</span>
          </span>
          <span class="disc">{p.disc}</span>
          <span class="yr">{p.year}</span>
        </a>
      ))}
    </div>
    <div class="preview">
      <div class="pv-img" id="pv-img"></div>
      <div class="pv-meta"><div class="pv-t" id="pv-t">{first.name}</div><div class="pv-d" id="pv-d">{first.lede}</div></div>
      <a class="pv-open" id="pv-open" href={first.href}>Open case study →</a>
    </div>
  </div>
</Base>

<style>
  /* page head */
  .phead { padding: 104px 0 64px; }
  .phead .k { font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--accent-text); margin-bottom: 22px; }
  .phead h1 { font-family: var(--font-display); font-weight: 700; font-size: clamp(38px, 5vw, 68px); line-height: .96; letter-spacing: -.03em; }
  .phead p { font-size: 18px; line-height: 1.5; color: var(--text-secondary); max-width: 56ch; margin-top: 24px; }

  /* featured pair */
  .feat { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; padding-bottom: 24px; }
  .fcard { position: relative; border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); display: block; transition: border-color .2s var(--ease-standard); }
  .fcard:hover { border-color: var(--border-strong); }
  .fcard .im { aspect-ratio: var(--ratio-landscape); overflow: hidden; }
  .fcard .im img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease-standard); }
  .fcard:hover .im img { transform: scale(1.03); }
  .fcard .meta { padding: 20px; display: flex; justify-content: space-between; align-items: flex-end; gap: 16px; }
  .fcard h3 { font-family: var(--font-display); font-weight: 600; font-size: 23px; letter-spacing: -.02em; }
  .fcard .yr { font-family: var(--font-mono); font-size: 12px; color: var(--accent-text); margin-top: 6px; display: block; }
  .fcard p { font-size: 13.5px; color: var(--text-secondary); margin-top: 10px; max-width: 42ch; }
  .fcard .disc { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .05em; color: var(--text-muted); text-align: right; white-space: nowrap; line-height: 1.8; }
  .badge { position: absolute; top: 16px; left: 16px; z-index: 2; font-family: var(--font-mono); font-size: 10px; letter-spacing: .06em; text-transform: uppercase; padding: 4px 8px; border-radius: var(--radius-none); backdrop-filter: blur(6px); }
  .badge.client { background: rgba(255, 90, 31, .16); color: var(--accent-300); border: 1px solid rgba(255, 90, 31, .35); }
  .badge.concept { background: var(--badge-concept-bg); color: var(--badge-concept-tx); border: 1px solid var(--border-strong); }

  /* filter bar */
  .filters { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; padding: 24px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); position: sticky; top: 0; background: var(--bg); z-index: 20; }
  .filters .fl-k { font-family: var(--font-mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted); margin-right: 6px; }
  .filters button { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .05em; text-transform: uppercase; color: var(--text-muted); background: none; border: 1px solid var(--border-strong); border-radius: var(--radius-none); padding: 7px 12px; cursor: pointer; transition: color .2s var(--ease-standard), border-color .2s var(--ease-standard), background .2s var(--ease-standard); }
  .filters button:hover { color: var(--text); }
  .filters button.on { color: var(--on-accent); background: var(--accent-fill); border-color: var(--accent-fill); }
  .filters .div { width: 1px; height: 20px; background: var(--border-strong); margin: 0 4px; }

  /* index + preview */
  .index-wrap { display: grid; grid-template-columns: 1fr 380px; gap: 48px; align-items: start; padding: 24px 0 96px; }
  .idx-head, .idx-row { display: grid; grid-template-columns: 34px 1.5fr .9fr 56px; gap: 16px; align-items: center; }
  .idx-head { padding: 12px 0; border-bottom: 1px solid var(--border); }
  .idx-head span { font-family: var(--font-mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted); }
  .idx-head span:last-child { text-align: right; }
  .idx-row { padding: 20px 0; border-bottom: 1px solid var(--border); cursor: pointer; transition: padding-left .2s var(--ease-standard); }
  .idx-row:hover, .idx-row.active { padding-left: 10px; }
  .idx-row .ix { font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); }
  .idx-row.active .ix { color: var(--accent-text); }
  .idx-row .nm { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .idx-row .nm b { font-family: var(--font-sans); font-weight: 600; font-size: 20px; letter-spacing: -.015em; color: var(--text-secondary); transition: color .2s var(--ease-standard); }
  .idx-row:hover .nm b, .idx-row.active .nm b { color: var(--text); }
  .idx-row .nm .ty { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .06em; text-transform: uppercase; padding: 3px 6px; border-radius: var(--radius-none); border: 1px solid var(--border-strong); color: var(--text-muted); }
  .idx-row .nm .ty.client { color: var(--accent-text); border-color: rgba(255, 90, 31, .35); }
  .idx-row .disc { font-family: var(--font-mono); font-size: 10.5px; text-transform: uppercase; letter-spacing: .04em; color: var(--text-muted); }
  .idx-row .yr { font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary); text-align: right; }
  .idx-row.hidden { display: none; }
  .preview { position: sticky; top: 96px; border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); }
  .preview .pv-img { aspect-ratio: var(--ratio-classic); position: relative; background: var(--surface-raised); }
  .preview .pv-img :global(img) { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity .32s var(--ease-standard); }
  .preview .pv-img :global(img.show) { opacity: 1; }
  .preview .pv-meta { padding: 18px; }
  .preview .pv-meta .pv-t { font-family: var(--font-display); font-weight: 600; font-size: 22px; letter-spacing: -.02em; }
  .preview .pv-meta .pv-d { font-family: var(--font-sans); font-size: 13.5px; color: var(--text-secondary); margin-top: 10px; line-height: 1.55; }
  .preview .pv-open { display: block; border-top: 1px solid var(--border); padding: 14px 18px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; text-transform: uppercase; color: var(--text-secondary); }
  .preview .pv-open:hover { color: var(--accent-text); }

  @media (max-width: 1100px) {
    .feat { grid-template-columns: 1fr; }
    .index-wrap { grid-template-columns: 1fr; }
    .preview { display: none; }
  }
  @media (max-width: 900px) {
    .phead { padding: 56px 0 40px; }
  }
  @media (max-width: 560px) {
    .idx-head { display: none; }
    .idx-row { grid-template-columns: 24px 1fr; gap: 10px; }
    .idx-row .disc, .idx-row .yr { display: none; }
  }
</style>

<script>
  // Index -> sticky preview + single-select filter (type or discipline).
  const rows = [...document.querySelectorAll<HTMLAnchorElement>('.idx-row')];
  const pvImg = document.getElementById('pv-img');
  const pvT = document.getElementById('pv-t');
  const pvD = document.getElementById('pv-d');
  const pvOpen = document.getElementById('pv-open');
  const imgs: Record<string, HTMLImageElement> = {};

  function setPreview(r: HTMLAnchorElement) {
    if (!pvImg || !pvT || !pvD) return;
    rows.forEach((x) => x.classList.remove('active'));
    r.classList.add('active');
    const src = r.dataset.img;
    if (src && !imgs[src]) {
      const im = new Image();
      im.src = src;
      im.alt = r.dataset.t ?? '';
      pvImg.appendChild(im);
      imgs[src] = im;
    }
    pvImg.querySelectorAll('img').forEach((i) => i.classList.remove('show'));
    if (src) requestAnimationFrame(() => imgs[src]!.classList.add('show'));
    pvT.textContent = r.dataset.t ?? '';
    pvD.textContent = r.dataset.d ?? '';
    const href = r.getAttribute('href');
    if (pvOpen && href && href !== '#') pvOpen.setAttribute('href', href);
  }

  rows.forEach((r) => {
    r.addEventListener('mouseenter', () => setPreview(r));
    r.addEventListener('focus', () => setPreview(r));
  });
  if (rows[0]) setPreview(rows[0]);

  const fbtns = [...document.querySelectorAll<HTMLButtonElement>('#filters button')];
  fbtns.forEach((b) => {
    b.addEventListener('click', () => {
      fbtns.forEach((x) => x.classList.remove('on'));
      b.classList.add('on');
      const f = b.dataset.f ?? 'all';
      let firstVisible: HTMLAnchorElement | null = null;
      rows.forEach((r) => {
        const ok = f === 'all' || (r.dataset.tags ?? '').split(' ').includes(f);
        r.classList.toggle('hidden', !ok);
        if (ok && !firstVisible) firstVisible = r;
      });
      if (firstVisible) setPreview(firstVisible);
    });
  });
</script>
