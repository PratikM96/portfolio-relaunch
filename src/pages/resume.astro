---
/**
 * Resume — Pratik Mehta. Layout ported from _reference/mockups/resume.html; CONTENT is
 * now sourced from the authoritative Resume Master (Drive), so every role gets a
 * full entry rather than collapsing earlier work into a footnote.
 *
 * Roles, titles, dates, employment types, metrics, the self-initiated systems,
 * education, and expertise + tools all track the Resume Master — reconcile there
 * first, then mirror here.
 */
import Base from '../layouts/Base.astro';
import StatFigure from '../components/StatFigure.astro';

const PDF = '/pratik-mehta-resume.pdf'; // exported from the Resume Master, lives in public/
const LINKEDIN = 'https://www.linkedin.com/in/pratikm96';

// Chronological work history (Resume Master). Each role is its own entry.
const experience = [
  {
    title: 'Creative Technologist',
    org: 'Independent Creative Systems Practice',
    meta: 'New York',
    when: 'Apr 2024 — Present',
    bullets: [
      'Run an independent creative systems practice, rebuilding my workflow around AI-assisted production across research, positioning, concept development, UI, motion, and quality control.',
      'Developed three self-initiated concept systems (The Ninth, Level, and WISP) spanning brand identity, product UI, AI interaction models, motion, and launch thinking across gaming, tech, and live-media use cases.',
      'Applied the workflow in select local and online brand projects to test AI-assisted production in real creative contexts.',
    ],
  },
  {
    title: 'Marketing Manager',
    org: 'SPORTIME Clubs',
    meta: 'Full-Time · New York',
    when: 'Jan 2023 — Mar 2024',
    bullets: [
      'Owned marketing across 13+ clubs and 25+ social accounts during a major growth period, leading 3+ social and design reports plus club-level creative leads.',
      'Built a video-first content engine that drove 11.7M cross-platform impressions and nearly 17,000 net new followers in one year.',
      'Turned content production into a repeatable multi-platform system, increasing Reels output by 2,115% year over year.',
      'Helped launch the SPORTIME Pickleball vertical and directed creative for the $75M JMTA flagship expansion.',
    ],
  },
  {
    title: 'Social Media Director',
    org: 'The Forest Road Company',
    meta: 'Full-Time · Remote',
    when: 'May 2022 — Dec 2022',
    bullets: [
      'Led brand social and paid content for a media-finance firm, pairing daily creative execution with campaign tracking and executive reporting.',
      'Conceived and executed still and video campaigns across brand channels, including daily X content and LinkedIn paid.',
      'Translated campaign performance into recommendations for senior leadership, delivering roughly $90 cost per lead on LinkedIn Lead Gen campaigns.',
    ],
  },
  {
    title: 'Social and Graphic Manager',
    org: 'DealNews',
    meta: 'Full-Time · Remote',
    when: 'Jul 2020 — May 2022',
    bullets: [
      'Ran social, paid, and in-house design as one function for a major deals platform, closing the loop between creative decisions and channel performance.',
      'Managed social content and paid campaigns anchored by a roughly 110,000-follower Facebook community plus Instagram and LinkedIn channels.',
      'Served as lead designer across landing pages, app updates, email, infographics, logos, and sales materials.',
      'Supported ecommerce growth through landing pages converting at roughly 7% median and email programs with a 30% open rate.',
    ],
  },
  {
    title: 'Associate Designer',
    org: 'Richard Attias and Associates',
    meta: 'Full-Time · New York',
    when: 'Apr 2019 — Dec 2019',
    bullets: [
      'Produced environmental, print, digital, social, web, and app prototype assets for large-scale global conferences and high-profile events.',
      'Built and supported the FII 2019 design platform, a global event with 6,000+ senior-level attendees and speakers from 30+ countries.',
      'Kept creative consistent from screens to rooms to printed programs across international handoffs and on-site production days.',
    ],
  },
  {
    title: 'Graphic and Motion Designer',
    org: 'Agency FiveEighty',
    meta: 'Internship · New York',
    when: 'Sep 2018 — Feb 2019',
    bullets: [
      'Produced motion graphics, title sequences, and broadcast-ready marketing collateral from concept to final delivery for Spectrum, the New York Jets, Coca-Cola, and FISLL.',
      'Delivered 15- and 30-second campaign cutdowns across multiple aspect ratios and deliverable formats.',
    ],
  },
  {
    title: 'Designer',
    org: 'Pipeline Medical',
    meta: 'Internship · Remote',
    when: 'Jun 2017 — Aug 2017',
    bullets: [
      "Built Pipeline Medical's brand identity and B2B supplier marketplace from zero, from logo system through core procurement screens.",
      'Delivered developer handoff assets, display ads, social assets, and buyer-education collateral for launch.',
    ],
  },
  {
    title: 'Marketing and Design Team Lead',
    org: 'SR Love and Care',
    meta: 'Volunteer · New York',
    when: 'Feb 2016 — May 2020',
    bullets: [
      'Built and led a volunteer marketing team for a global humanitarian nonprofit, growing it from 5 to over 15 members across four years.',
      'Founded a dedicated design team as demand grew, setting workflows, standards, and mentorship before handing off the function.',
    ],
  },
  {
    title: 'Marketing Coordinator',
    org: 'Kumon',
    meta: 'Part-Time · New York',
    when: 'Mar 2014 — Aug 2019',
    bullets: [
      'Produced print and digital marketing collateral, ran paid campaigns, and managed social media for one Kumon center, building an early model for connecting creative production to local lead generation.',
    ],
  },
];

// Self-initiated portfolio systems (concepts — scope, not client results).
const concepts = [
  {
    title: 'The Ninth',
    sub: 'Esports Membership OS',
    when: '2026',
    disc: 'Brand · UI/UX · AI · Motion',
    bullets: [
      'Unaffiliated concept treating esports fans as members rather than a passive audience. Brand system, product UI across 40 screens, 8 AI-assisted features, motion states, and social-first launch routes.',
    ],
  },
  {
    title: 'Level',
    sub: 'Responsible Prediction Market App',
    when: '2025',
    disc: 'Brand · UI/UX · AI · Motion',
    bullets: [
      'Prediction-market app concept built around responsible use and product trust. Thirty screens including guardrail flows, probability and risk visualizations, and onboarding logic.',
    ],
  },
  {
    title: 'WISP',
    sub: 'Live AI Host Presence',
    when: '2024',
    disc: 'UI/UX · AI · Motion',
    bullets: [
      'Real-time AI host presence for live and streamed formats, combining interaction logic, interface design, prompt behavior, and motion across 3 live use cases.',
    ],
  },
];

// Generic practice-level metrics (career totals, not a single client).
const metrics = [
  { v: '10+', u: '', l: 'years of cross-channel experience' },
  { v: '20+', u: '', l: 'brands, partners, and organizations' },
  { v: '10,000+', u: '', l: 'assets produced' },
  { v: '190+', u: '', l: 'video and motion assets produced' },
];

const expertise = [
  'Brand Strategy', 'Creative Direction', 'Production Design', 'Social & Content',
  'UI/UX', 'Motion & Video', 'Performance Marketing', 'AI Workflow', 'Team Leadership',
];
const toolsCreative = [
  'Figma', 'Photoshop', 'Illustrator', 'InDesign', 'After Effects', 'Premiere Pro',
  'Framer', 'Webflow', 'WordPress', 'HTML/CSS', 'Git',
];
const toolsMarketing = [
  'Meta Ads', 'Google Ads', 'GA4', 'Tableau', 'SQL',
  'HubSpot', 'Klaviyo', 'Mailchimp', 'Sprout', 'Claude',
  'Firefly', 'Midjourney', 'Runway', 'Sora', 'ElevenLabs',
];
---

<Base
  image="/og/resume.png"
  ogType="profile"
  title="Resume · Pratik Mehta"
  description="Pratik Mehta, creative marketing lead with 10+ years across brand, social, content, motion, UI/UX, and performance, built as one connected system."
  activeNav="resume"
>
  <header class="rhead">
    <div class="page-kicker rev">[ Resume ]</div>
    <div class="rhead-row rev">
      <h1 class="page-h1">Pratik Mehta</h1>
      <span class="rhead-loc">New York</span>
      <div class="sub">Creative Marketing Lead · Brand · Social · Content · UI/UX · Motion · Performance</div>
      <div class="rhead-links"><a href="mailto:mehtadpratik@gmail.com">mehtadpratik@gmail.com</a> · <a href={LINKEDIN} target="_blank" rel="noopener">LinkedIn</a></div>
    </div>
  </header>

  {/* BY THE NUMBERS — practice totals + resume download */}
  <section class="rnumbers rev">
    <div class="rmet">
      {metrics.map((m) => (
        <div class="c"><div class="f"><StatFigure value={m.v} unit={m.u} /></div><div class="l">{m.l}</div></div>
      ))}
      <a class="c c-dl" href={PDF} target="_blank" rel="noopener">Download PDF ↓</a>
      <div class="src">Across the practice, brand to performance</div>
    </div>
  </section>

  <div class="rgrid">
    <div class="rmain">
      {/* SUMMARY */}
      <section class="rsec rev">
        <div class="blabel"><span class="c">[ 01 ]</span><span class="t">Summary</span><span class="rule"></span></div>
        <p class="summary"><strong>Creative marketing lead with 10+ years connecting brand, social, content, UI/UX, motion, and performance as one system.</strong> I build the creative and the system that makes it perform: concept, production, channel logic, and the reporting loop after launch. My career spans in-house, agency, nonprofit, and independent work across 20+ brands and organizations, including a video-first social program that drove 11.7M impressions in a single year. Since 2024, I've run an independent creative systems practice built around AI-assisted production.</p>
      </section>

      {/* EXPERIENCE — full history */}
      <section class="rsec rev">
        <div class="blabel"><span class="c">[ 02 ]</span><span class="t">Experience</span><span class="rule"></span></div>
        {
          experience.map((x) => (
            <div class="exp">
              <div class="top">
                <h3>{x.title}</h3>
                <div class="org">{x.org}</div>
                {x.meta && <div class="emeta">{x.meta}</div>}
                <div class="when">{x.when}</div>
              </div>
              <ul>{x.bullets.map((b) => <li set:html={b} />)}</ul>
            </div>
          ))
        }
      </section>

      {/* SELF-INITIATED SYSTEMS */}
      <section class="rsec rev">
        <div class="blabel"><span class="c">[ 03 ]</span><span class="t">Self-initiated systems · concepts</span><span class="rule"></span></div>
        {
          concepts.map((c) => (
            <div class="exp">
              <div class="top">
                <h3>{c.title}</h3>
                <div class="org">{c.sub}</div>
                <div class="emeta">{c.disc}</div>
                <div class="when">{c.when}</div>
              </div>
              <ul>{c.bullets.map((b) => <li>{b}</li>)}</ul>
            </div>
          ))
        }
      </section>

    </div>

    <aside class="raside rev">
      <div class="rblock">
        <div class="blabel"><span class="c">[ 04 ]</span><span class="t">Education</span><span class="rule"></span></div>
        <div class="edu"><div class="d">B.S. Computer Science</div><div class="s">New York University · 2014 — 2017</div></div>
      </div>
      <div class="rblock">
        <div class="blabel"><span class="c">[ 05 ]</span><span class="t">Expertise</span><span class="rule"></span></div>
        <div class="chips">{expertise.map((x) => <span>{x}</span>)}</div>
      </div>
      <div class="rblock">
        <div class="blabel"><span class="c">[ 06 ]</span><span class="t">Tools</span><span class="rule"></span></div>
        <div class="skills">
          <div class="skg"><div class="kk">Design, Video &amp; Product</div><div class="chips">{toolsCreative.map((x) => <span>{x}</span>)}</div></div>
          <div class="skg"><div class="kk">Marketing, Analytics &amp; AI</div><div class="chips">{toolsMarketing.map((x) => <span>{x}</span>)}</div></div>
        </div>
      </div>
    </aside>
  </div>
</Base>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .rmet .f {
    font-family: var(--t-display-font); font-weight: var(--t-display-weight); letter-spacing: var(--t-display-track);
  }
  .exp h3,
  .exp .org,
  .rblock .edu .d {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .rhead .sub,
  .exp .emeta,
  .exp .when,
  .rmet .c-dl,
  .rmet .src,
  .skg .kk {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }
  .rhead-loc, .rhead-links,
  .chips span {
    font-family: var(--t-data-font); font-weight: var(--t-data-weight); letter-spacing: var(--t-data-track);
  }


  /* header: name + title on the left, location/contact aligned on the right */
  .rhead { padding: 104px 0 36px; }
  .rhead-row { display: grid; grid-template-columns: 1fr auto; column-gap: 32px; row-gap: 14px; align-items: baseline; }
  .rhead .sub { font-size: 12px; text-transform: uppercase; color: var(--text-secondary); }
  .rhead-loc, .rhead-links { font-size: 11.5px; color: var(--text-secondary); text-align: right; justify-self: end; }
  .rhead-links a:hover { color: var(--accent-text); }

  /* by-the-numbers band (sits directly under the header) */
  .rnumbers { margin-bottom: 8px; }

  /* layout */
  .rgrid { display: grid; grid-template-columns: minmax(0, 1fr) 280px; gap: 64px; padding: 56px 0 96px; align-items: start; }
  .rmain { min-width: 0; }
  .rsec { margin-bottom: 56px; }
  /* shared reading measure so the summary and the experience/concept bullets
     line up to one column width (rem, not ch, so the two font sizes align) */
  .summary { font-size: 18px; line-height: 1.6; color: var(--text-secondary); max-width: 48rem; }
  .summary strong { color: var(--text); font-weight: 600; }

  /* experience */
  .exp { padding-bottom: 28px; margin-bottom: 28px; border-bottom: 1px solid var(--border); }
  .exp:last-of-type { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  /* title + date on row 1, org + type/location on row 2 (date and meta align right) */
  .exp .top { display: grid; grid-template-columns: 1fr auto; column-gap: 20px; row-gap: 4px; align-items: baseline; }
  .exp h3 { font-size: 21px; }
  .exp .org { font-size: 15px; color: var(--accent-text); justify-self: end; text-align: right; }
  .exp .emeta { font-size: 10.5px; text-transform: uppercase; color: var(--text-muted); }
  .exp .when { font-size: 11px; text-transform: uppercase; color: var(--text-muted); white-space: nowrap; justify-self: end; text-align: right; }
  .exp ul { list-style: none; margin-top: 14px; display: flex; flex-direction: column; gap: 9px; max-width: 48rem; }
  .exp li { font-size: 14.5px; line-height: 1.55; color: var(--text-secondary); padding-left: 18px; position: relative; }
  .exp li::before { content: "•"; position: absolute; left: 0; color: var(--text-secondary); }
  .exp li :global(b) { color: var(--text); font-weight: 600; }

  /* metrics band */
  .rmet { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; }
  .rmet .c { background: var(--surface); padding: 20px; }
  .rmet .f { font-size: clamp(22px, 2.4vw, 30px); line-height: 1; }
  .rmet .l { font-size: 11.5px; line-height: 1.45; color: var(--text-secondary); margin-top: 9px; }
  /* download cell: a metric-cell-sized CTA on the far right of the band */
  .rmet .c-dl { display: flex; align-items: center; justify-content: center; text-align: center; padding: 20px; font-size: 12px; text-transform: uppercase; color: var(--text); background: var(--surface); transition: color .2s var(--ease-standard), background .2s var(--ease-standard); }
  .rmet .c-dl:hover { color: var(--on-accent); background: var(--accent-fill); }
  .rmet .src { grid-column: 1 / -1; background: var(--surface); padding: 12px 20px; font-size: 10px; text-transform: uppercase; color: var(--text-muted); }

  /* aside: sticky beside the main column, headers match the section labels */
  .raside { position: sticky; top: 40px; align-self: start; display: flex; flex-direction: column; gap: 34px; }
  .raside .blabel { margin-bottom: 16px; }
  .rblock .edu .d { font-size: 16px; }
  .rblock .edu .s { font-size: 13px; color: var(--text-secondary); margin-top: 4px; }
  .skills { display: flex; flex-direction: column; gap: 18px; }
  .skg .kk { font-size: 10px; text-transform: uppercase; color: var(--accent-text); margin-bottom: 10px; }
  /* expertise + tools as small mono "system label" chips (sharp, data-layer) */
  .chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .chips span { font-size: 10.5px; color: var(--text-secondary); background: var(--surface); border: 1px solid var(--border-strong); border-radius: var(--radius-none); padding: 4px 8px; line-height: 1.3; }

  @media (max-width: 1000px) {
    .rgrid { grid-template-columns: 1fr; gap: 40px; }
    .raside { position: static; }
    .rmet { grid-template-columns: repeat(2, 1fr); }
    /* 4 metrics + download = 5 cells; at 2 cols the download would dangle alone,
       so let it span the full row as a wide CTA */
    .rmet .c-dl { grid-column: 1 / -1; }
  }
  @media (max-width: 900px) {
    .rhead { padding: 56px 0 40px; }
    .rhead-row { grid-template-columns: 1fr; row-gap: 8px; }
    .rhead-loc, .rhead-links { text-align: left; justify-self: start; }
  }
  @media (max-width: 560px) { .exp .when { text-align: left; } }
</style>
