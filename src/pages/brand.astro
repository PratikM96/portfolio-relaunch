---
/**
 * Brand — One System. The site's living brand reference, rebuilt from the
 * authoritative One-System-Brand-Guidelines (Drive) rather than the early
 * mockup. Rules are transcribed from that source of truth; tokens (color,
 * spacing, radius, motion) are read LIVE from src/styles/tokens.css at build
 * time and rendered with var(), so the page can't drift from the real system.
 *
 * Source of truth: One-System-Brand-Guidelines v1.0. Voice rules come from
 * System Master (the brand doc defers voice to it; summarized per CLAUDE.md).
 * The Formats section (social / reel / lower-third) is ported as live mockups
 * rendered from tokens at true export dimensions. Chrome from Base.astro /
 * global.css.
 */
import Base from '../layouts/Base.astro';
import Brandmark from '../components/Brandmark.astro';
// Token file read as a raw string at build time (Vite ?raw) — no node:fs,
// so the page bundles cleanly for the Cloudflare Worker runtime.
import tokensCss from '../styles/tokens.css?raw';
const tokenValue = (name: string) => {
  const m = tokensCss.match(new RegExp(`${name}\\s*:\\s*([^;]+);`));
  return m ? m[1].trim() : '';
};
const hex = (name: string) => tokenValue(name).replace('#', '').toUpperCase();
const px = (name: string) => tokenValue(name).replace('px', '');

// Live ramps + scales — every value is read from the token file.
const neutral = ['--n-0', '--n-50', '--n-100', '--n-200', '--n-300', '--n-400', '--n-500', '--n-550', '--n-600', '--n-700', '--n-800', '--n-900', '--n-950'];
const accent = ['--accent-50', '--accent-100', '--accent-200', '--accent-300', '--accent-400', '--accent-500', '--accent-600', '--accent-700', '--accent-800', '--accent-900'];
const spacing = [
  { token: '--space-xs', name: 'xs' }, { token: '--space-sm', name: 'sm' },
  { token: '--space-md', name: 'md' }, { token: '--space-lg', name: 'lg' },
  { token: '--space-xl', name: 'xl' }, { token: '--space-2xl', name: '2xl' },
  { token: '--space-3xl', name: '3xl' }, { token: '--space-4xl', name: '4xl' },
];
const radii = [
  { token: '--radius-none', name: 'none' }, { token: '--radius-sm', name: 'sm' },
  { token: '--radius-md', name: 'md', star: true }, { token: '--radius-lg', name: 'lg' },
  { token: '--radius-xl', name: 'xl' }, { token: '--radius-full', name: 'full' },
];
const durations = [
  { token: '--dur-fast', name: 'fast', w: 48 }, { token: '--dur-base', name: 'base', w: 80, star: true },
  { token: '--dur-slow', name: 'slow', w: 128 }, { token: '--dur-deliberate', name: 'deliberate', w: 200 },
];

const stepOf = (t: string) => t.replace(/--(n|accent)-/, '');
---

<Base
  title="Brand · One System · Pratik Mehta"
  description="One System is the design system this site runs on: foundation, logo, type, color, layout, motion, and access. Rendered from the live tokens, so it can't drift."
  activeNav="brand"
>
  <header class="bhero">
    <div class="page-kicker rev">[ Brand ] · One System · v1.0</div>
    <h1 class="rev page-h1">The brand,<br />built like a <span class="signal">product.</span></h1>
    <p class="rev">One System is the identity this site runs on: foundation, logo, type, color, layout, motion, and access, in one place. It is a working reference and a case study of the thinking behind it. The page renders from the live tokens, so it can't drift from the real site.</p>
  </header>

  {/* 01 FOUNDATION */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 01 ]</span><span class="t">Foundation · the spine</span><span class="rule"></span></div>
    <p class="intro">Creative built like a system and accountable to what it does after it ships. The breadth is the proof of the idea, not a separate selling point.</p>
    <div class="frow" style="border-top:none">
      <div class="fspec">tagline</div>
      <div class="fsamp tagline">One system, end to end<span class="signal">.</span></div>
    </div>
    <div class="frow"><div class="fspec">reserve line</div><div class="fsamp">Built, not briefed.</div></div>
    <div class="frow"><div class="fspec">accent signal</div><div class="fsamp mono">Signal orange · #{hex('--accent-500')} · used once, to do one job</div></div>
  </section>

  {/* 02 LOGO */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 02 ]</span><span class="t">Logo · the loop</span><span class="rule"></span></div>
    <p class="intro">One continuous stroke that closes on the orange node: the system, end to end, as a mark. Default to the primary lockup. The wordmark carries the circular period; the lockups don't.</p>
    <div class="logoset rev">
      <div class="tile"><div class="lockrow"><Brandmark size={52} title={undefined} /><span class="wm">Pratik Mehta</span></div></div>
      <div class="tile dark"><div class="lockrow"><Brandmark size={52} title={undefined} /><span class="wm">Pratik Mehta</span></div></div>
      <div class="tile"><div class="lockcol"><Brandmark size={44} title={undefined} /><span class="wm" style="font-size:24px">Pratik Mehta</span></div></div>
      <div class="tile"><span class="wm" style="font-size:31px">Pratik Mehta<span class="period"></span></span></div>
    </div>
    <div class="cap">primary (ink / paper) · stacked · wordmark with period. Use the mono mark where the accent can't appear.</div>

    <div class="subhead">Clear space &amp; minimum size</div>
    <div class="clearrow">
      <div><div class="csbox"><Brandmark size={72} title={undefined} /></div><div class="cap">keep-out = 0.25 × mark height</div></div>
      <div class="mincol"><Brandmark size={24} title={undefined} /><div class="cap">mark · 24px floor</div></div>
      <div class="mincol"><Brandmark size={16} title={undefined} /><div class="cap">favicon cut · 16px</div></div>
    </div>

    <div class="subhead">Never do this</div>
    <div class="dont rev">
      <div class="dcard"><span class="x">✕</span><div class="dwrap"><div class="d-stretch"><Brandmark size={52} title={undefined} /></div><span class="dlab">stretch or distort</span></div></div>
      <div class="dcard"><span class="x">✕</span><div class="dwrap"><div class="d-recolor"><Brandmark size={52} title={undefined} /></div><span class="dlab">recolor the node</span></div></div>
      <div class="dcard"><span class="x">✕</span><div class="dwrap"><span class="wm" style="font-size:24px">Pratik Mehta<span class="period sq"></span></span><span class="dlab">square the period</span></div></div>
      <div class="dcard"><span class="x">✕</span><div class="dwrap"><div class="d-shadow"><Brandmark size={52} title={undefined} /></div><span class="dlab">add effects</span></div></div>
      <div class="dcard"><span class="x">✕</span><div class="dwrap"><div class="d-rotate"><Brandmark size={52} title={undefined} /></div><span class="dlab">rotate or tilt</span></div></div>
      <div class="dcard"><span class="x">✕</span><div class="dwrap"><div class="d-onaccent"><Brandmark size={40} title={undefined} /></div><span class="dlab">accent node on orange</span></div></div>
    </div>
  </section>

  {/* 03 TYPE */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 03 ]</span><span class="t">Type · three faces, one system</span><span class="rule"></span></div>
    <p class="intro">Clash Display carries the hero. Clash Grotesk carries headings and body. Berkeley Mono (TX-02) carries the system layer: labels, data, and code. The Clash families use 400, 600, and 700. Berkeley Mono uses 400 Regular and 500 Medium, with Medium reserved for emphasis labels such as the primary button.</p>
    <div class="ty"><div class="k">display · Clash Display 700<br />-3%</div><div class="v disp" style="font-size:clamp(36px,5vw,56px)">One system<span class="signal">.</span></div></div>
    <div class="ty"><div class="k">h1 · Clash Grotesk 700<br />-2%</div><div class="v" style="font-weight:700;font-size:36px;letter-spacing:-0.02em">Creative as one system</div></div>
    <div class="ty"><div class="k">h3 · Clash Grotesk 600</div><div class="v" style="font-weight:600;font-size:22px;letter-spacing:-0.015em">Selected work</div></div>
    <div class="ty"><div class="k">body · Clash Grotesk 400<br />lh 1.65</div><div class="v" style="font-size:16px;line-height:1.65;color:var(--text-secondary)">The work stays coherent and the loop closes.</div></div>
    <div class="ty"><div class="k">label · TX-02<br />+8% / uppercase</div><div class="v mono" style="font-size:12px;letter-spacing:0.08em;text-transform:uppercase">Brand · Social · Performance</div></div>
    <div class="ty"><div class="k">emphasis · TX-02 Medium 500</div><div class="v mono" style="font-size:12px;font-weight:500;letter-spacing:0.04em;text-transform:uppercase">View work</div></div>
  </section>

  {/* 04 COLOR */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 04 ]</span><span class="t">Color · warm monochrome, one accent</span><span class="rule"></span></div>
    <p class="intro">A warm neutral ramp from paper to ink, a single signal-orange accent, and a restrained state set. Both light and dark are first-class.</p>
    <div class="subhead">Neutral · warm ramp</div>
    <div class="ramp">
      {neutral.map((t) => (
        <div class="chip"><div class="sw" style={`background: var(${t})`}></div><div class="hx">{stepOf(t)}<br />{hex(t)}</div></div>
      ))}
    </div>
    <div class="subhead">Accent · signal orange <span class="signal">★ 500</span></div>
    <div class="ramp">
      {accent.map((t) => (
        <div class="chip"><div class="sw" style={`background: var(${t});${t === '--accent-500' ? ' outline:2px solid var(--text); outline-offset:1px;' : ''}`}></div><div class="hx">{stepOf(t)}{t === '--accent-500' ? '★' : ''}<br />{hex(t)}</div></div>
      ))}
    </div>
    <div class="subhead">Surfaces · light &amp; dark</div>
    <div class="panels">
      <div class="panel" style="background:var(--n-50)"><div class="p-lab" style="color:var(--n-500)">light · paper</div><div class="p-h" style="color:var(--n-950)">One system<span style="color:var(--accent-500)">.</span></div><div class="p-b" style="color:var(--n-600)">Body in graphite on paper. The accent does one job.</div><span class="p-pill" style="background:var(--accent-50);color:var(--accent-800)">brand · social · perf</span></div>
      <div class="panel" style="background:var(--n-950);border-color:var(--n-800)"><div class="p-lab" style="color:var(--n-400)">dark · ink</div><div class="p-h" style="color:var(--n-50)">One system<span style="color:var(--accent-500)">.</span></div><div class="p-b" style="color:var(--n-400)">Same system inverted. Orange stays the single accent.</div><span class="p-pill" style="background:var(--n-800);color:var(--accent-400)">brand · social · perf</span></div>
    </div>
  </section>

  {/* 05 LAYOUT */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 05 ]</span><span class="t">Layout · a 4px base</span><span class="rule"></span></div>
    <p class="intro">Everything measures from a 4px unit. Layout is a {px('--grid-cols')}-column grid, max-width {px('--grid-max-width')}, {px('--grid-gutter')} gutters, {px('--grid-margin')} margins. Radius base is {px('--radius-md')}px; the mono system layer uses sharp 0 corners.</p>
    <div class="scale">
      {spacing.map((s) => (
        <div class="s-row"><div class="s-lab">{s.name} · {tokenValue(s.token)}</div><div class="s-bar" style={`width: var(${s.token})`}></div></div>
      ))}
    </div>
    <div class="grid-demo" aria-hidden="true">{Array.from({ length: 12 }).map(() => (<div class="gcol"></div>))}</div>
    <div class="mono muted gridnote">{px('--grid-cols')} columns · max {px('--grid-max-width')} · gutter {px('--grid-gutter')} · margin {px('--grid-margin')}</div>
    <div class="subhead" style="margin-top:36px">Radius</div>
    <div class="r-row">
      {radii.map((r) => (
        <div><div class="r-box" style={`border-radius: var(${r.token})`}></div><div class="hx">{r.name}{r.star ? ' ★' : ''} · {r.name === 'full' ? 'pill' : px(r.token)}</div></div>
      ))}
    </div>
  </section>

  {/* 06 MOTION */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 06 ]</span><span class="t">Motion · functional, not decorative</span><span class="rule"></span></div>
    <p class="intro">Quick and confident. One ease-out curve, four durations, short travel, no bounce. Reels inherit this: cuts over fades, snap transitions.</p>
    <div class="motion">
      <div class="durs">
        {durations.map((d) => (
          <div class="d-row"><div class="d-lab">{d.name} · {tokenValue(d.token)}{d.star ? ' ★' : ''}</div><div class="d-bar" style={`width:${d.w}px`}></div></div>
        ))}
        <div class="mono muted" style="font-size:10.5px;margin-top:14px">ease · {tokenValue('--ease-standard')}</div>
      </div>
      <div class="hoverdemo"><a class="btn btn-p" href="/work">View work</a><div class="mono muted" style="font-size:10.5px">Hover</div></div>
    </div>
  </section>

  {/* 07 ACCESSIBILITY */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 07 ]</span><span class="t">Accessibility · tuned to WCAG AA</span><span class="rule"></span></div>
    <p class="intro">The single orange signal can't sit on top of itself. Three rules carry most of it.</p>
    <div class="rules rev">
      <div class="rule-card"><div class="rule-k">Orange text</div><div class="rule-b">On light, orange text is accent-700 (#{hex('--accent-700')}), never 500. On dark, accent-400.</div></div>
      <div class="rule-card"><div class="rule-k">On orange fills</div><div class="rule-b">Text and the logo on an orange surface are ink, never white. The mark goes monochrome so the node doesn't blend.</div></div>
      <div class="rule-card"><div class="rule-k">State colors</div><div class="rule-b">State fills for indicators; the darker -text variants when used as text.</div></div>
    </div>
    <table>
      <thead><tr><th>Pair</th><th>Ratio</th><th>Verdict</th></tr></thead>
      <tbody>
        <tr><td>Ink on paper</td><td class="r">17.6:1</td><td class="aa">AAA</td></tr>
        <tr><td>Secondary #615D52 on paper</td><td class="r">5.9:1</td><td class="aa">AA</td></tr>
        <tr><td>Accent-700 text on paper</td><td class="r">4.8:1</td><td class="aa">AA</td></tr>
        <tr><td>Ink on orange fill</td><td class="r">6.3:1</td><td class="aa">AA</td></tr>
        <tr><td>Paper on ink (dark)</td><td class="r">17.6:1</td><td class="aa">AAA</td></tr>
      </tbody>
    </table>
  </section>

  {/* 08 FORMATS */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 08 ]</span><span class="t">Formats · the brand, in format</span><span class="rule"></span></div>
    <p class="intro">How the system shows up as social posts, reel frames, and a lower-third. Placeholder content at true export dimensions, rendered live so the mockups re-theme with the page.</p>

    <div class="subhead">Social · 1080 × 1080</div>
    <div class="fmt-stage">
      <div class="unit">
        <div class="fr w360"><div class="b1x1 bg-paper"><div class="fmt-pad">
          <div class="kick k-acc">// placeholder label</div>
          <div class="fmt-disp t-ink" style="font-size:128px;line-height:0.98">One system,<br />end to end<span class="t-acc">.</span></div>
          <div class="ffoot"><div class="foot2 k-mut">mehtapratik.com</div><Brandmark size={104} title={undefined} class="fmt-mk-ink" /></div>
        </div></div></div>
        <div class="spec"><b>feed</b> · statement</div>
      </div>
      <div class="unit">
        <div class="fr w360"><div class="b1x1 bg-ink"><div class="fmt-pad">
          <div class="kick k-acc">// placeholder label</div>
          <div class="fmt-disp t-paper" style="font-size:104px;line-height:1.0">Placeholder<br />headline goes<br />right here<span class="t-acc">.</span></div>
          <div class="ffoot"><div class="foot2 k-paper">@pratikm96</div><Brandmark size={104} title={undefined} class="fmt-mk-paper" /></div>
        </div></div></div>
        <div class="spec"><b>feed</b> · inverted</div>
      </div>
      <div class="unit">
        <div class="fr w360"><div class="b1x1 bg-paper"><div class="fmt-pad">
          <div class="kick k-mut">metric · placeholder</div>
          <div><div class="fmt-disp t-acc" style="font-size:240px;line-height:0.9">00.0</div><div class="kick k-ink" style="font-size:30px;margin-top:16px">metric label goes here</div></div>
          <div class="ffoot"><div class="foot2 k-mut">mehtapratik.com</div><Brandmark size={104} title={undefined} class="fmt-mk-ink" /></div>
        </div></div></div>
        <div class="spec"><b>feed</b> · data</div>
      </div>
    </div>

    <div class="subhead">Reel / story · 1080 × 1920</div>
    <div class="fmt-stage">
      <div class="unit">
        <div class="fr w270"><div class="b9x16 bg-ink"><div class="fmt-pad fmt-pad-v" style="justify-content:space-between">
          <div class="kick k-acc">reel · intro frame</div>
          <div><div class="fmt-disp t-paper" style="font-size:150px;line-height:0.96">Built,<br />not<br />briefed<span class="t-acc">.</span></div><div class="rule8" style="margin-top:40px"></div></div>
          <div class="ffoot"><div class="foot2 k-paper" style="line-height:1.5">placeholder<br />caption line</div><Brandmark size={104} title={undefined} class="fmt-mk-paper" /></div>
        </div></div></div>
        <div class="spec"><b>reel</b> · intro</div>
      </div>
      <div class="unit">
        <div class="fr w270"><div class="b9x16 bg-accent"><div class="fmt-pad fmt-pad-v" style="justify-content:space-between">
          <div class="kick k-ink">end card</div>
          <div class="fmt-disp t-ink" style="font-size:140px;line-height:0.96">Let's<br />build<span style="opacity:0.55">.</span></div>
          <div class="ffoot"><div class="foot2 t-ink" style="line-height:1.5">mehtapratik.com<br />@pratikm96</div><Brandmark size={104} title={undefined} class="fmt-mk-mono" /></div>
        </div></div></div>
        <div class="spec"><b>reel</b> · end card · accent surface → mono mark</div>
      </div>
    </div>

    <div class="subhead">Lower-third · 1920 × 1080</div>
    <div class="fmt-stage">
      <div class="unit">
        <div class="fr w480"><div class="b16x9 lt-bg">
          <div class="lt-ph">▢ video placeholder</div>
          <div class="lt-bar"><div class="lt-edge"></div><div class="lt-box"><div class="lt-name">Pratik Mehta</div><div class="lt-title">Creative &amp; Marketing Strategist</div></div></div>
        </div></div>
        <div class="spec"><b>caption</b> · over video</div>
      </div>
    </div>
  </section>

  {/* 09 VOICE */}
  <section class="bsec">
    <div class="blabel"><span class="c">[ 09 ]</span><span class="t">Voice · source: System Master</span><span class="rule"></span></div>
    <p class="intro">Direct, specific, natural, not over-polished, not obviously AI-written. Lead with the answer. No inflated claims, no buzzwords, no unsupported proof. No em or en dashes.</p>
    <div class="voice rev">
      <div class="vcol do"><div class="h">Do</div><ul><li>Lead with the answer</li><li>Name real numbers, verified</li><li>Plain, confident sentences</li><li>Label concept work clearly</li></ul></div>
      <div class="vcol dont-col"><div class="h">Don't</div><ul><li>Inflate or overclaim</li><li>Reach for buzzwords</li><li>Over-polish into AI-speak</li><li>Imply concepts are client work</li></ul></div>
    </div>
  </section>
</Base>

<style>
  .bhero { padding: 104px 0 64px; }
  .bhero p { font-size: 18px; line-height: 1.5; color: var(--text-secondary); max-width: 56ch; margin-top: 24px; }
  .bsec { padding: 96px 0; }
  .bsec .intro { font-size: 16px; line-height: 1.6; color: var(--text-secondary); max-width: 66ch; margin-bottom: 36px; }
  .subhead { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; text-transform: uppercase; color: var(--text-muted); margin: 40px 0 16px; }
  .cap { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-top: 12px; line-height: 1.5; }
  .mono { font-family: var(--font-mono); }
  .muted { color: var(--text-muted); }

  /* foundation */
  .frow { display: flex; align-items: baseline; gap: 24px; padding: 16px 0; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .fspec { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); width: 200px; flex-shrink: 0; }
  .fsamp { flex: 1; min-width: 240px; color: var(--text); font-size: 16px; }
  .fsamp.tagline { font-family: var(--font-display); font-weight: 700; font-size: 24px; letter-spacing: -.02em; }
  .fsamp.mono { font-family: var(--font-mono); font-size: 14px; }

  /* logo */
  .logoset { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 14px; }
  .tile { background: var(--n-0); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; display: flex; align-items: center; justify-content: center; min-height: 140px; }
  .tile.dark { background: var(--n-950); border-color: var(--n-800); }
  .tile :global(.brandmark) { color: var(--n-950); }
  .tile.dark :global(.brandmark) { color: var(--n-50); }
  .lockrow { display: flex; align-items: center; gap: 16px; }
  .lockcol { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .wm { font-family: var(--font-display); font-weight: 700; font-size: 30px; letter-spacing: -.025em; color: var(--n-950); }
  .tile.dark .wm { color: var(--n-50); }
  .period { display: inline-block; width: .16em; height: .16em; border-radius: 50%; background: var(--accent-fill); vertical-align: baseline; margin-left: .04em; }
  .period.sq { border-radius: 0; }
  .clearrow { display: flex; align-items: flex-end; gap: 48px; flex-wrap: wrap; }
  .clearrow :global(.brandmark) { color: var(--text); }
  .csbox { display: inline-block; border: 1px dashed var(--accent-fill); padding: 24px; border-radius: var(--radius-sm); }
  .mincol { display: flex; flex-direction: column; align-items: center; gap: 10px; }

  /* don'ts */
  .dont { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 8px; }
  .dcard { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px; position: relative; min-height: 124px; display: flex; align-items: center; justify-content: center; }
  .dcard :global(.brandmark) { color: var(--text); }
  .x { position: absolute; top: 12px; left: 12px; width: 20px; height: 20px; border-radius: 50%; background: var(--danger); color: #fff; font-family: var(--font-mono); font-size: 12px; line-height: 20px; text-align: center; }
  .dwrap { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .dlab { font-family: var(--font-mono); font-size: 10.5px; color: var(--text-secondary); text-align: center; line-height: 1.5; }
  .d-stretch :global(.brandmark) { transform: scaleX(1.7); }
  .d-recolor :global(.node) { fill: #2A4DFF; }
