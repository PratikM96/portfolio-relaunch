---
/**
 * Journal index — notes on systems, brand, and AI.
 * Collection-driven: renders a lead post + list when entries exist, and falls back
 * to a clean empty state when none do (no placeholder entries).
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });

// Published, newest first.
const posts = (await getCollection('journal'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const lead = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== lead?.id);
const meta = (p: (typeof posts)[number]) =>
  [p.data.topic, fmt(p.data.date), p.data.readingTime].filter(Boolean).join(' · ');
---

<Base
  image="/og/journal.png"
  title="Journal · Pratik Mehta"
  description="Working notes on building creative as a system, what makes work distinctive, and where AI actually changes the job."
  activeNav="journal"
>
  <header class="phead">
    <div class="page-kicker">[ Journal ] · on systems, brand, and AI</div>
    <h1 class="rev page-h1">Working notes,<br />not <span class="signal">hot takes.</span></h1>
    <p class="rev">Short pieces on building creative as a system, what makes work distinctive, and where AI actually changes the job, not where it's just hype.</p>
  </header>

  <div class="jr-body">
  {
    posts.length === 0 ? (
      <div class="card jr-empty rev">
        <span class="jr-tag">[ Coming soon ]</span>
        <p>The first notes go up after launch.</p>
      </div>
    ) : (
      <Fragment>
        {lead && (
          <a class="card lead-post lead-post--textonly rev" href={`/journal/${lead.id}`}>
            <div class="body">
              <div class="cats">
                {lead.data.tags.map((t, i) => (
                  <span class:list={['tag', i === lead.data.tags.length - 1 && 'acc']}>{t}</span>
                ))}
              </div>
              <h2>{lead.data.title}</h2>
              <p>{lead.data.excerpt}</p>
              <div class="m">{[fmt(lead.data.date), lead.data.readingTime].filter(Boolean).join(' · ')}</div>
            </div>
          </a>
        )}

        {rest.length > 0 && (
          <div class="plist rev">
            {rest.map((p) => (
              <a class="prow" href={`/journal/${p.id}`}>
                <div>
                  <div class="t">{p.data.title}</div>
                  <div class="ex">{p.data.excerpt}</div>
                </div>
                <div class="m">{meta(p)}</div>
              </a>
            ))}
          </div>
        )}
      </Fragment>
    )
  }
  </div>
</Base>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .lead-post h2 {
    font-family: var(--t-h2-font); font-weight: var(--t-h2-weight); letter-spacing: var(--t-h2-track);
  }
  .prow .t {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .jr-empty .jr-tag,
  .lead-post .m,
  .prow .m {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }


  .phead { padding: var(--space-4xl) 0 var(--space-3xl); }
  .phead p { font-size: 18px; line-height: 1.5; color: var(--text-secondary); max-width: 56ch; margin-top: var(--space-lg); }

  /* consistent gap before the footer divider (matches the 96px section rhythm) */
  .jr-body { padding-bottom: var(--space-4xl); }

  /* empty state — surface from global .card */
  .jr-empty { padding: var(--space-2xl); display: flex; flex-direction: column; gap: var(--space-md); align-items: flex-start; }
  .jr-empty .jr-tag { font-size: 11px; text-transform: uppercase; color: var(--accent-text); }
  .jr-empty p { font-size: 18px; color: var(--text-secondary); }

  /* .tag / .tag.acc come from global.css */

  /* lead post — surface from global .card */
  .lead-post { display: grid; gap: var(--space-xl); overflow: hidden; margin-bottom: var(--space-3xl); }
  .lead-post .body { min-width: 0; padding: var(--space-xl); display: flex; flex-direction: column; justify-content: center; }
  .lead-post .cats { display: flex; flex-wrap: wrap; gap: var(--space-xs); margin-bottom: var(--space-md); }
  .lead-post h2 { font-size: clamp(26px, 3vw, 36px); line-height: 1.05; margin-bottom: var(--space-md); }
  .lead-post p { font-size: 15px; line-height: 1.6; color: var(--text-secondary); max-width: 48ch; }
  .lead-post .m { font-size: 11px; text-transform: uppercase; color: var(--text-muted); margin-top: var(--space-lg); }

  /* list */
  .plist { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
  .prow { display: grid; grid-template-columns: 1fr auto; gap: var(--space-xl); align-items: baseline; padding: var(--space-xl) 0; border-bottom: 1px solid var(--border); transition: padding-left .2s var(--ease-standard); }
  .prow:hover { padding-left: var(--space-sm); }
  .prow .t { font-size: clamp(20px, 2.4vw, 26px); color: var(--text-secondary); transition: color .2s var(--ease-standard); }
  .prow:hover .t { color: var(--text); }
  .prow .ex { font-size: 14px; color: var(--text-muted); margin-top: var(--space-xs); max-width: 60ch; }
  .prow .m { font-size: 11px; text-transform: uppercase; color: var(--text-muted); white-space: nowrap; text-align: right; }

  @media (max-width: 900px) { .phead { padding: var(--space-3xl) 0 var(--space-2xl); } .prow .m { display: none; } }
</style>
