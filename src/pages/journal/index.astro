---
/**
 * Journal index — notes on systems, brand, and AI. Ported from _reference/mockups/blog.html.
 * Collection-driven: renders a lead post + list when entries exist, and a clean
 * empty state until the first posts publish after launch (no placeholder entries).
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });

// Published, newest first. (Empty until launch.)
const posts = (await getCollection('journal'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const lead = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== lead?.id);
const meta = (p: (typeof posts)[number]) =>
  [p.data.topic, fmt(p.data.date), p.data.readingTime].filter(Boolean).join(' · ');
---

<Base
  image="/og/journal.png"
  title="Journal · Pratik Mehta"
  description="Working notes on building creative as a system, what makes work distinctive, and where AI actually changes the job."
  activeNav="journal"
>
  <header class="phead">
    <div class="page-kicker">[ Journal ] · on systems, brand, and AI</div>
    <h1 class="rev page-h1">Working notes,<br />not <span class="signal">hot takes.</span></h1>
    <p class="rev">Short pieces on building creative as a system, what makes work distinctive, and where AI actually changes the job, not where it's just hype.</p>
  </header>

  <div class="jr-body">
  {
    posts.length === 0 ? (
      <div class="card jr-empty rev">
        <span class="jr-tag">[ Coming soon ]</span>
        <p>The first notes go up after launch.</p>
      </div>
    ) : (
      <Fragment>
        {lead && (
          <a class="card lead-post rev" href={`/journal/${lead.id}`}>
            {lead.data.cover && (
              <div class="im"><img src={lead.data.cover} alt={lead.data.coverAlt ?? lead.data.title} /></div>
            )}
            <div class="body">
              <div class="cats">
                {lead.data.tags.map((t, i) => (
                  <span class:list={['tag', i === lead.data.tags.length - 1 && 'acc']}>{t}</span>
                ))}
              </div>
              <h2>{lead.data.title}</h2>
              <p>{lead.data.excerpt}</p>
              <div class="m">{[fmt(lead.data.date), lead.data.readingTime].filter(Boolean).join(' · ')}</div>
            </div>
          </a>
        )}

        {rest.length > 0 && (
          <div class="plist rev">
            {rest.map((p) => (
              <a class="prow" href={`/journal/${p.id}`}>
                <div>
                  <div class="t">{p.data.title}</div>
                  <div class="ex">{p.data.excerpt}</div>
                </div>
                <div class="m">{meta(p)}</div>
              </a>
            ))}
          </div>
        )}
      </Fragment>
    )
  }
  </div>
</Base>

<style>
  .phead { padding: 104px 0 64px; }
  .phead p { font-size: 18px; line-height: 1.5; color: var(--text-secondary); max-width: 56ch; margin-top: 24px; }

  /* consistent gap before the footer divider (matches the 96px section rhythm) */
  .jr-body { padding-bottom: 96px; }

  /* empty state — surface from global .card */
  .jr-empty { padding: 48px; display: flex; flex-direction: column; gap: 14px; align-items: flex-start; }
  .jr-empty .jr-tag { font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--accent-text); }
  .jr-empty p { font-size: 18px; color: var(--text-secondary); }

  /* .tag / .tag.acc come from global.css */

  /* lead post — surface from global .card */
  .lead-post { display: grid; grid-template-columns: 1.1fr .9fr; gap: 32px; overflow: hidden; margin-bottom: 56px; }
  .lead-post .im { overflow: hidden; }
  .lead-post .im img { width: 100%; height: 100%; object-fit: cover; min-height: 280px; }
  .lead-post .body { min-width: 0; padding: 36px; display: flex; flex-direction: column; justify-content: center; }
  .lead-post .cats { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
  .lead-post h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(26px, 3vw, 36px); letter-spacing: -.025em; line-height: 1.05; margin-bottom: 14px; }
  .lead-post p { font-size: 15px; line-height: 1.6; color: var(--text-secondary); max-width: 48ch; }
  .lead-post .m { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; text-transform: uppercase; color: var(--text-muted); margin-top: 22px; }

  /* list */
  .plist { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
  .prow { display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: baseline; padding: 28px 0; border-bottom: 1px solid var(--border); transition: padding-left .2s var(--ease-standard); }
  .prow:hover { padding-left: 10px; }
  .prow .t { font-family: var(--font-display); font-weight: 600; font-size: clamp(20px, 2.4vw, 26px); letter-spacing: -.02em; color: var(--text-secondary); transition: color .2s var(--ease-standard); }
  .prow:hover .t { color: var(--text); }
  .prow .ex { font-size: 14px; color: var(--text-muted); margin-top: 8px; max-width: 60ch; }
  .prow .m { font-family: var(--font-mono); font-size: 11px; letter-spacing: .04em; text-transform: uppercase; color: var(--text-muted); white-space: nowrap; text-align: right; }

  @media (max-width: 1000px) { .lead-post { grid-template-columns: 1fr; } }
  @media (max-width: 900px) { .phead { padding: 56px 0 40px; } .prow .m { display: none; } }
</style>
