---
/**
 * Journal article template — /journal/[slug]. Ported from _reference/mockups/blog-post.html.
 * Renders a post from the `journal` collection: header, optional cover, the markdown
 * body, and an optional margin (pull-quote + related note). Reuses the case-study
 * rail variant (back link + meta lines), so no new Base variant is needed.
 *
 * One page per non-draft entry under src/content/journal/; none if there are
 * none.
 */
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('journal');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({ params: { slug: post.id }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const d = post.data;
const { Content } = await render(post);

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });

const scoreboard = [
  d.topic && { k: 'Topic', v: d.topic },
  { k: 'Published', v: fmt(d.date) },
  d.readingTime && { k: 'Read', v: d.readingTime },
].filter((x): x is { k: string; v: string } => Boolean(x));

const metaLine = [fmt(d.date), d.readingTime].filter(Boolean).join(' · ');

// Other published posts for the "More writing" lists (newest first, current excluded).
const others = (await getCollection('journal'))
  .filter((p) => !p.data.draft && p.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

// Shared author blurb — rendered in the desktop rail and the mobile post-foot.
const bio =
  'Pratik builds creative, social, and performance as one system, from the idea to what it does after it ships. Open to creative or marketing leadership roles.';

// Structured data — BlogPosting + breadcrumb.
const origin = Astro.site ? Astro.site.origin : 'https://mehtapratik.com';
const postUrl = `${origin}/journal/${post.id}`;
const schema = [
  {
    '@type': 'BlogPosting',
    '@id': `${postUrl}#post`,
    headline: d.title,
    description: d.excerpt,
    url: postUrl,
    image: `${origin}/og/journal.png`,
    datePublished: d.date.toISOString(),
    author: { '@id': `${origin}/#pratik` },
    publisher: { '@id': `${origin}/#pratik` },
    keywords: d.tags.join(', '),
    isPartOf: { '@id': `${origin}/#website` },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${origin}/` },
      { '@type': 'ListItem', position: 2, name: 'Journal', item: `${origin}/journal` },
      { '@type': 'ListItem', position: 3, name: d.title },
    ],
  },
];
---

<Base
  variant="case-study"
  image="/og/journal.png"
  ogType="article"
  schema={schema}
  title={`${d.title} · Journal · Pratik Mehta`}
  description={d.excerpt}
  sections={[]}
  scoreboard={scoreboard}
  back={{ href: '/journal', label: '← Journal · all writing' }}
>
  <header class="ahead">
    {d.tags.length > 0 && (
      <div class="cats">
        {d.tags.map((t, i) => (
          <span class:list={['tag', i === d.tags.length - 1 && 'acc']}>{t}</span>
        ))}
      </div>
    )}
    <h1 class="rev page-h1">{d.title}</h1>
    <div class="m">{metaLine}</div>
  </header>


  {/* Left console rail extras (journal only): author bio + other posts. Fills the
      case-study rail's otherwise-empty section-nav area. Hidden ≤900px (rail
      collapses to the drawer there); the mobile equivalent is .post-foot below. */}
  <Fragment slot="rail">
    <div class="rail-bio">
      <span class="bio-k">About</span>
      <p>{bio}</p>
      <a class="rail-bio-about" href="/about">More about Pratik →</a>
    </div>
    {others.length > 0 && (
      <div class="rail-more">
        <span class="bio-k">More writing</span>
        <nav class="rail-more-nav">
          {others.map((p) => (
            <a href={`/journal/${p.id}`}>{p.data.title}</a>
          ))}
        </nav>
      </div>
    )}
  </Fragment>

  <article class="article">
    <div class="amain rev">
      <Content />
    </div>
    {d.pullquote && (
      <aside class="amargin rev">
        <div class="m-quote"><p>{d.pullquote}</p></div>
      </aside>
    )}
  </article>

  {/* Mobile equivalent of the rail extras (≤900px, where the rail is hidden). */}
  <section class="post-foot rev">
    <div class="pf-about">
      <span class="pf-k">About</span>
      <p>{bio}</p>
      <a href="/about">More about Pratik →</a>
    </div>
    {others.length > 0 && (
      <div class="pf-more">
        <span class="pf-k">More writing</span>
        <ul>
          {others.map((p) => (
            <li><a href={`/journal/${p.id}`}>{p.data.title}</a></li>
          ))}
        </ul>
      </div>
    )}
  </section>
</Base>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .amain :global(h2) {
    font-family: var(--t-h2-font); font-weight: var(--t-h2-weight); letter-spacing: var(--t-h2-track);
  }
  .amain :global(h3),
  .amain :global(blockquote),
  .m-quote p,
  .pf-more a {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .ahead .m,
  .pf-k,
  .pf-about a {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }


  .ahead { padding: var(--space-4xl) 0 var(--space-3xl); max-width: 74ch; }
  .ahead .cats { display: flex; gap: var(--space-xs); margin-bottom: var(--space-lg); }
  .ahead .m { font-size: 11px; text-transform: uppercase; color: var(--text-muted); margin-top: var(--space-lg); }

  /* .tag / .tag.acc come from global.css */


  .article { display: grid; grid-template-columns: minmax(0, 1fr) 280px; gap: var(--space-3xl); align-items: start; padding-bottom: var(--space-4xl); }
  .amain { max-width: 70ch; }
  /* body copy comes from the post markdown — style the rendered elements globally */
  .amain :global(p) { font-size: 18px; line-height: 1.7; color: var(--text-secondary); margin-bottom: var(--space-lg); }
  .amain :global(p:first-child) { font-size: 21px; line-height: 1.6; color: var(--text); }
  .amain :global(h2) { font-size: 26px; margin: var(--space-2xl) 0 var(--space-md); }
  .amain :global(h3) { font-size: 20px; margin: var(--space-xl) 0 var(--space-sm); }
  .amain :global(strong) { color: var(--text); font-weight: 600; }
  .amain :global(a) { color: var(--accent-text); text-decoration: underline; text-underline-offset: 3px; }
  .amain :global(ul), .amain :global(ol) { margin: 0 0 var(--space-lg) var(--space-lg); color: var(--text-secondary); }
  .amain :global(li) { margin-bottom: var(--space-xs); line-height: 1.6; }
  .amain :global(blockquote) { border-left: 2px solid var(--accent-fill); padding-left: var(--space-lg); margin: 0 0 var(--space-lg); color: var(--text); }

  .amargin { display: flex; flex-direction: column; gap: var(--space-lg); position: sticky; top: 48px; }
  .m-quote { border-top: 1px solid var(--border-strong); padding-top: var(--space-md); }
  .m-quote p { font-size: 18px; line-height: 1.25; color: var(--text); }

  /* mobile post-foot: author + more writing, shown only where the rail is hidden */
  .post-foot { display: none; }
  .pf-k { font-size: 10px; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: var(--space-md); }
  .pf-about p { font-size: 15px; line-height: 1.6; color: var(--text-secondary); max-width: 60ch; }
  .pf-about a { display: inline-block; margin-top: var(--space-sm); font-size: 11px; text-transform: uppercase; color: var(--accent-text); }
  .pf-more ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-md); }
  .pf-more a { font-size: 17px; line-height: 1.2; color: var(--text-secondary); transition: color .2s var(--ease-standard); }
  .pf-more a:hover { color: var(--text); }

  @media (max-width: 1000px) {
    .article { grid-template-columns: 1fr; gap: var(--space-xl); }
    .amargin { position: static; flex-direction: row; flex-wrap: wrap; }
    .amargin > * { flex: 1; min-width: 220px; }
  }
  @media (max-width: 900px) {
    .ahead { padding: var(--space-3xl) 0 var(--space-2xl); }
    .article { padding-bottom: var(--space-2xl); }
    .post-foot {
      display: flex; flex-direction: column; gap: var(--space-xl);
      padding-top: var(--space-2xl); padding-bottom: var(--space-4xl);
      border-top: 1px solid var(--border);
    }
  }
</style>
