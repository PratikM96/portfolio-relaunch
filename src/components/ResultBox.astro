---
/**
 * ResultBox.astro — client proof: a row of verified headline metrics plus a
 * verified testimonial. Client-only; concept work uses a ScopeBox instead
 * (scope + rationale, no results claimed).
 *
 * Metrics + testimonial must be verified facts. Invent nothing.
 */
type Metric = { value: string; unit?: string; label: string };
interface Props {
  metrics: Metric[];
  testimonial: { quote: string; source: string };
}
const { metrics, testimonial } = Astro.props;
---

<div class="cs-result rev">
  <div class="grid">
    {
      metrics.map((m) => (
        <div class="r">
          <div class="f">{m.value}{m.unit && <span class="u">{m.unit}</span>}</div>
          <div class="l">{m.label}</div>
        </div>
      ))
    }
  </div>
  <div class="cs-quote">
    <span class="mk">"</span>
    <div>
      <p>{testimonial.quote}</p>
      <div class="who">{testimonial.source}</div>
    </div>
  </div>
</div>

<style>
  .cs-result { border: 1px solid var(--border-strong); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); }
  .cs-result .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); }
  .cs-result .r { background: var(--surface); padding: 30px 24px; }
  .cs-result .r .f { font-family: var(--font-display); font-weight: 700; font-size: clamp(32px, 3.8vw, 50px); letter-spacing: -0.025em; line-height: 1; }
  .cs-result .r .f .u { color: var(--accent-text); }
  .cs-result .r .l { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text-muted); margin-top: 12px; line-height: 1.5; max-width: 24ch; }
  .cs-quote { padding: 36px 28px; border-top: 1px solid var(--border); display: flex; gap: 18px; align-items: flex-start; }
  .cs-quote .mk { font-family: var(--font-display); font-weight: 700; font-size: 40px; color: var(--accent-text); line-height: .6; }
  .cs-quote p { font-size: 17px; line-height: 1.55; color: var(--text); max-width: 62ch; }
  .cs-quote .who { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-muted); margin-top: 14px; }

  @media (max-width: 1100px) { .cs-result .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cs-result .grid { grid-template-columns: 1fr; } }
</style>
