---
/**
 * MarginRail.astro — the case-study margin column. Renders a stack of margin
 * modules beside the prose. Module types: meta | stat | quote | note (single
 * or stacked, in any order). Data-driven so a section only shows what it has.
 */
import StatFigure from './StatFigure.astro';
type Module =
  | { type: 'meta'; label: string; rows: { k: string; v: string }[] }
  | { type: 'stat'; label: string; value: string; unit?: string; desc: string }
  | { type: 'quote'; quote: string; who: string }
  | { type: 'note'; label: string; text: string };
interface Props {
  modules: Module[];
}
const { modules } = Astro.props;
---

<aside class="cs-margin">
  {
    modules.map((m) => {
      if (m.type === 'meta') {
        return (
          <div class="m-meta">
            <div class="m-label">{m.label}</div>
            {m.rows.map((r) => (
              <div class="row"><span class="k">{r.k}</span><span class="v">{r.v}</span></div>
            ))}
          </div>
        );
      }
      if (m.type === 'stat') {
        return (
          <div class="m-stat">
            <div class="m-label">{m.label}</div>
            <div class="f"><StatFigure value={m.value} unit={m.unit} /></div>
            <div class="d">{m.desc}</div>
          </div>
        );
      }
      if (m.type === 'quote') {
        return (
          <div class="m-quote">
            <div class="mk">"</div>
            <p>{m.quote}</p>
            <div class="who">{m.who}</div>
          </div>
        );
      }
      return (
        <div class="m-note">
          <div class="m-label">{m.label}</div>
          <p>{m.text}</p>
        </div>
      );
    })
  }
</aside>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .m-stat .f,
  .m-quote .mk {
    font-family: var(--t-display-font); font-weight: var(--t-display-weight); letter-spacing: var(--t-display-track);
  }
  .m-quote p {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .cs-margin .m-label,
  .m-meta .row .k,
  .m-quote .who {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }

  .cs-margin { display: flex; flex-direction: column; gap: var(--space-lg); }
  .cs-margin .m-label { font-size: 10px; text-transform: uppercase; color: var(--text-muted); margin-bottom: var(--space-sm); }
  .m-stat { border-top: 1px solid var(--border-strong); padding-top: var(--space-md); }
  .m-stat .f { font-size: 42px; line-height: 1; }
  .m-stat .d { font-size: 13px; line-height: 1.5; color: var(--text-secondary); margin-top: var(--space-sm); }
  .m-note { border-left: 2px solid var(--border-strong); padding-left: var(--space-md); }
  .m-note p { font-size: 13.5px; line-height: 1.55; color: var(--text-secondary); }
  .m-meta { display: flex; flex-direction: column; gap: var(--space-md); border-top: 1px solid var(--border-strong); padding-top: var(--space-md); }
  .m-meta .row .k { font-size: 10px; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: var(--space-2xs); }
  .m-meta .row .v { font-size: 13.5px; color: var(--text); line-height: 1.4; }
  .m-quote { border-top: 1px solid var(--border-strong); padding-top: var(--space-md); }
  .m-quote .mk { font-size: 30px; color: var(--accent-text); line-height: .5; height: 16px; }
  .m-quote p { font-size: 19px; line-height: 1.22; color: var(--text); margin-top: var(--space-xs); }
  .m-quote .who { font-size: 10px; text-transform: uppercase; color: var(--text-muted); margin-top: var(--space-sm); }

  /* When the layout collapses, modules flow as a row of cards. */
  @media (max-width: 1100px) {
    .cs-margin { flex-direction: row; flex-wrap: wrap; gap: var(--space-lg); }
    .cs-margin > * { flex: 1; min-width: 220px; }
  }
</style>
