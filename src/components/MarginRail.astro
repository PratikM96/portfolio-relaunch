---
/**
 * MarginRail.astro — the case-study margin column. Renders a stack of margin
 * modules beside the prose. Module types: meta | stat | quote | note (single
 * or stacked, in any order). Data-driven so a section only shows what it has.
 */
type Module =
  | { type: 'meta'; label: string; rows: { k: string; v: string }[] }
  | { type: 'stat'; label: string; value: string; unit?: string; desc: string }
  | { type: 'quote'; quote: string; who: string }
  | { type: 'note'; label: string; text: string };
interface Props {
  modules: Module[];
}
const { modules } = Astro.props;
---

<aside class="cs-margin">
  {
    modules.map((m) => {
      if (m.type === 'meta') {
        return (
          <div class="m-meta">
            <div class="m-label">{m.label}</div>
            {m.rows.map((r) => (
              <div class="row"><span class="k">{r.k}</span><span class="v">{r.v}</span></div>
            ))}
          </div>
        );
      }
      if (m.type === 'stat') {
        return (
          <div class="m-stat">
            <div class="m-label">{m.label}</div>
            <div class="f">{m.value}{m.unit && <span class="u">{m.unit}</span>}</div>
            <div class="d">{m.desc}</div>
          </div>
        );
      }
      if (m.type === 'quote') {
        return (
          <div class="m-quote">
            <div class="mk">"</div>
            <p>{m.quote}</p>
            <div class="who">{m.who}</div>
          </div>
        );
      }
      return (
        <div class="m-note">
          <div class="m-label">{m.label}</div>
          <p>{m.text}</p>
        </div>
      );
    })
  }
</aside>

<style>
  .cs-margin { display: flex; flex-direction: column; gap: 22px; }
  .cs-margin .m-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 10px; }
  .m-stat { border-top: 1px solid var(--border-strong); padding-top: 16px; }
  .m-stat .f { font-family: var(--font-display); font-weight: 700; font-size: 42px; letter-spacing: -0.025em; line-height: 1; }
  .m-stat .f .u { color: var(--accent-text); }
  .m-stat .d { font-size: 13px; line-height: 1.5; color: var(--text-secondary); margin-top: 10px; }
  .m-note { border-left: 2px solid var(--border-strong); padding-left: 16px; }
  .m-note p { font-size: 13.5px; line-height: 1.55; color: var(--text-secondary); }
  .m-meta { display: flex; flex-direction: column; gap: 14px; border-top: 1px solid var(--border-strong); padding-top: 16px; }
  .m-meta .row .k { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 4px; }
  .m-meta .row .v { font-size: 13.5px; color: var(--text); line-height: 1.4; }
  .m-quote { border-top: 1px solid var(--border-strong); padding-top: 16px; }
  .m-quote .mk { font-family: var(--font-display); font-weight: 700; font-size: 30px; color: var(--accent-text); line-height: .5; height: 16px; }
  .m-quote p { font-family: var(--font-display); font-weight: 600; font-size: 19px; line-height: 1.22; letter-spacing: -0.015em; color: var(--text); margin-top: 8px; }
  .m-quote .who { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-muted); margin-top: 12px; }

  /* When the layout collapses, modules flow as a row of cards. */
  @media (max-width: 1100px) {
    .cs-margin { flex-direction: row; flex-wrap: wrap; gap: 24px; }
    .cs-margin > * { flex: 1; min-width: 220px; }
  }
</style>
