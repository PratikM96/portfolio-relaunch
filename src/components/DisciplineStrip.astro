---
/**
 * DisciplineStrip.astro — the five-discipline "system map" strip under the hero.
 * The five disciplines connect (+) into one system; the last carries no plus.
 */
const items = [
  { ix: '01', nm: 'Brand' },
  { ix: '02', nm: 'Social' },
  { ix: '03', nm: 'Content' },
  { ix: '04', nm: 'UI/UX' },
  { ix: '05', nm: 'Motion' },
  { ix: '06', nm: 'Performance' },
];
---

<section class="disc-strip">
  <div class="sysmap rev">
    {
      items.map((it, i) => (
        <div class="n">
          <div class="ix">{it.ix}</div>
          <div class="nm">{it.nm}</div>
          {i < items.length - 1 && <span class="ar">+</span>}
        </div>
      ))
    }
  </div>
</section>

<style>
  .disc-strip { padding-bottom: 8px; }
  .sysmap {
    display: grid; grid-template-columns: repeat(6, 1fr);
    border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden;
  }
  .sysmap .n { padding: 16px; border-right: 1px solid var(--border); position: relative; background: var(--surface); }
  .sysmap .n:last-child { border-right: none; }
  .sysmap .n .ix { font-family: var(--t-data-font); font-weight: var(--t-data-weight); letter-spacing: var(--t-data-track); font-size: 10px; color: var(--text-muted); }
  .sysmap .n .nm { font-weight: 600; font-size: 14px; margin-top: 7px; }
  .sysmap .n .ar {
    position: absolute; right: -7px; top: 50%; transform: translateY(-50%);
    font-family: var(--t-data-font); font-weight: var(--t-data-weight); letter-spacing: var(--t-data-track); font-size: 15px; line-height: 1; color: var(--accent-text);
    background: var(--surface); padding: 3px 3px; z-index: 3;
  }
  .sysmap .n:last-child .ar { display: none; }

  @media (max-width: 900px) {
    .sysmap { grid-template-columns: repeat(2, 1fr); }
    .sysmap .n .ar { display: none; }
  }
</style>
