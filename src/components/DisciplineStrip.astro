---
/**
 * DisciplineStrip.astro — the six-discipline "system map" strip under the hero.
 * The disciplines ARE the system; the cells and their shared border carry that,
 * so no connector glyph is needed between them.
 */
const items = [
  { ix: '01', nm: 'Brand' },
  { ix: '02', nm: 'Social' },
  { ix: '03', nm: 'Content' },
  { ix: '04', nm: 'UI/UX' },
  { ix: '05', nm: 'Motion' },
  { ix: '06', nm: 'Performance' },
];
---

<section class="disc-strip">
  <div class="sysmap rev">
    {
      items.map((it) => (
        <div class="n">
          <div class="ix">{it.ix}</div>
          <div class="nm">{it.nm}</div>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .sysmap .n .nm {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .sysmap .n .ix {
    font-family: var(--t-data-font); font-weight: var(--t-data-weight); letter-spacing: var(--t-data-track);
  }


  .disc-strip { padding-bottom: var(--space-xs); }
  .sysmap {
    display: grid; grid-template-columns: repeat(6, 1fr);
    border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden;
  }
  .sysmap .n { padding: var(--space-md); border-right: 1px solid var(--border); position: relative; background: var(--surface); }
  .sysmap .n:last-child { border-right: none; }
  .sysmap .n .ix { font-size: 10px; color: var(--text-muted); }
  /* h3 tier — a discipline name is a short title, same as a card title. It was
     `font-weight: 600` with no family, which inherited Grotesk at the `strong`
     weight and belonged to no tier. */
  .sysmap .n .nm {
    font-size: 14px; margin-top: var(--space-xs); color: var(--accent-text);
  }

  @media (max-width: 900px) {
    .sysmap { grid-template-columns: repeat(2, 1fr); }
  }
</style>
