---
/**
 * ProofBox.astro — the single proof block for EVERY case study, whatever its
 * engagement. One uniform stat style: a grid of proof figures (value + optional
 * accent unit) plus an optional note line. There is no metric-vs-scope split —
 * any entry's `proof.figures` render identically. Replaces ResultBox + ScopeBox.
 */
import StatFigure from './StatFigure.astro';
type Figure = { value: string; unit?: string; label: string };
interface Props {
  figures: Figure[];
  /** Optional caption/rationale under the figures. */
  note?: { label: string; text: string };
}
const { figures, note } = Astro.props;
// Grid columns track the figure count (3 figures -> 3 columns, no empty cell,
// wider cells that keep long values from overflowing). Capped at 4.
const cols = Math.min(figures.length, 4);
---

<div class="cs-proof rev">
  <div class="grid" style={`--cols:${cols}`}>
    {
      figures.map((f) => (
        <div class="r">
          <div class="f"><StatFigure value={f.value} unit={f.unit} /></div>
          <div class="l">{f.label}</div>
        </div>
      ))
    }
  </div>
  {note && (
    <div class="cs-note">
      <div class="m-label">{note.label}</div>
      <p>{note.text}</p>
    </div>
  )}
</div>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .cs-proof .r .f {
    font-family: var(--t-display-font); font-weight: var(--t-display-weight); letter-spacing: var(--t-display-track);
  }
  .cs-proof .r .l,
  .cs-note .m-label {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }

  .cs-proof { border: 1px solid var(--border-strong); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); }
  .cs-proof .grid { display: grid; grid-template-columns: repeat(var(--cols, 4), 1fr); gap: 1px; background: var(--border); }
  /* container-query sizing so the figure scales to the cell and never wraps;
     the unit is a smaller secondary run so long word-units fit on one line */
  .cs-proof .r { background: var(--surface); padding: 30px 24px; container-type: inline-size; }
  /* figure sizing/nowrap only; the number/accent split + accent styling live in StatFigure */
  /* proof figures are short (descriptions live in the label), so the number is full-size */
  .cs-proof .r .f { font-size: clamp(26px, 22cqi, 50px); line-height: 1; white-space: nowrap; }
  /* description: max two lines */
  .cs-proof .r .l { font-size: 10.5px; text-transform: uppercase; color: var(--text-muted); margin-top: 12px; line-height: 1.5; max-width: 24ch; display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .cs-note { padding: 30px 28px; border-top: 1px solid var(--border); }
  .cs-note .m-label { font-size: 10px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; }
  .cs-note p { font-size: 16px; line-height: 1.6; color: var(--text-secondary); max-width: 66ch; }

  @media (max-width: 1100px) { .cs-proof .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cs-proof .grid { grid-template-columns: 1fr; } }
</style>
