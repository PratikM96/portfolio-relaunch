---
/**
 * SysFlow.astro — the numbered step flow that shows the system (the
 * differentiator). Steps connect left-to-right; the last carries no arrow.
 */
type Step = { ix: string; title: string; text: string };
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---

<div class="sysflow rev">
  {
    steps.map((s, i) => (
      <div class="step">
        <div class="ix">{s.ix}</div>
        <h4>{s.title}</h4>
        <p>{s.text}</p>
        {i < steps.length - 1 && <span class="ar">→</span>}
      </div>
    ))
  }
</div>

<style>
  .sysflow { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 8px; }
  .sysflow .step { border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); padding: 24px; position: relative; }
  .sysflow .step .ix { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.06em; color: var(--accent-text); }
  .sysflow .step h4 { font-family: var(--font-sans); font-weight: 600; font-size: 17px; margin: 12px 0 8px; letter-spacing: -0.01em; }
  .sysflow .step p { font-size: 13.5px; line-height: 1.5; color: var(--text-secondary); }
  .sysflow .step .ar { position: absolute; right: -11px; top: 50%; transform: translateY(-50%); font-family: var(--font-mono); font-size: 13px; color: var(--text-muted); z-index: 2; }
  .sysflow .step:last-child .ar { display: none; }

  @media (max-width: 1100px) {
    .sysflow { grid-template-columns: repeat(2, 1fr); }
    .sysflow .step .ar { display: none; }
  }
  @media (max-width: 560px) { .sysflow { grid-template-columns: 1fr; } }
</style>
