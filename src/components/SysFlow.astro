---
/**
 * SysFlow.astro — the numbered step flow that shows the system (the
 * differentiator). Steps connect left-to-right; the last carries no arrow.
 */
type Step = { ix: string; title: string; text: string };
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---

<div class="sysflow rev">
  {
    steps.map((s, i) => (
      <div class="card step">
        <div class="ix">{s.ix}</div>
        <h3>{s.title}</h3>
        <p>{s.text}</p>
        {i < steps.length - 1 && <span class="ar">→</span>}
      </div>
    ))
  }
</div>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .sysflow .step h3 {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .sysflow .step .ix,
  .sysflow .step .ar {
    font-family: var(--t-data-font); font-weight: var(--t-data-weight); letter-spacing: var(--t-data-track);
  }

  .sysflow { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-md); margin-top: var(--space-xs); }
  /* surface comes from global .card */
  .sysflow .step { padding: var(--space-lg); position: relative; }
  .sysflow .step .ix { font-size: 10.5px; color: var(--accent-text); }
  .sysflow .step h3 { font-size: 17px; margin: var(--space-sm) 0 var(--space-xs); }
  .sysflow .step p { font-size: 13.5px; line-height: 1.5; color: var(--text-secondary); }
  .sysflow .step .ar { position: absolute; right: -11px; top: 50%; transform: translateY(-50%); font-size: 13px; color: var(--text-muted); z-index: 2; }
  .sysflow .step:last-child .ar { display: none; }

  @media (max-width: 1100px) {
    .sysflow { grid-template-columns: repeat(2, 1fr); }
    .sysflow .step .ar { display: none; }
  }
  @media (max-width: 560px) { .sysflow { grid-template-columns: 1fr; } }
</style>
