---
/**
 * Scoreboard.astro — the case-study hero board: a 4-up grid of cells.
 * A cell is either a plain meta cell or a `stat` cell: one uniform proof style
 * (large display figure + optional accent unit), the same for every entry.
 * There is no metric-vs-scope distinction.
 */
import StatFigure from './StatFigure.astro';
type Cell = {
  k: string;
  v: string;
  /** Render `v` as a large proof figure (with an optional accent unit). */
  stat?: boolean;
  /** Unit suffix (e.g. "M", "%", "screens") — stat cells only. */
  unit?: string;
  /** Force the whole figure to the signal accent (unitless measured results). */
  accent?: boolean;
};
interface Props {
  cells: Cell[];
}
const { cells } = Astro.props;
---

<div class="sb-board rev">
  {
    cells.map((c) => (
      <div class:list={['sb-cell', c.stat && 'stat']}>
        <div class="k">{c.k}</div>
        <div class:list={['v', c.accent && 'acc']}>{c.stat ? <StatFigure value={c.v} unit={c.unit} /> : c.v}</div>
      </div>
    ))
  }
</div>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .sb-cell.stat .v {
    font-family: var(--t-display-font); font-weight: var(--t-display-weight); letter-spacing: var(--t-display-track);
  }
  .sb-cell .v {
    font-family: var(--t-h3-font); font-weight: var(--t-h3-weight); letter-spacing: var(--t-h3-track);
  }
  .sb-cell .k {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }

  .sb-board {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
    background: var(--border); border: 1px solid var(--border);
    border-radius: var(--radius-md); overflow: hidden; margin-top: var(--space-2xl);
  }
  .sb-cell { background: var(--surface); padding: var(--space-lg) var(--space-lg); container-type: inline-size; }
  .sb-cell .k { font-size: 10px; text-transform: uppercase; color: var(--text-muted); margin-bottom: var(--space-sm); }
  .sb-cell .v { font-size: 16px; color: var(--text); line-height: 1.35; }
  /* accent flag: paint the whole figure with the signal colour (StatFigure's own
     accent runs already use it, so a unitless value like "100" turns orange too) */
  .sb-cell .v.acc { color: var(--accent-text); }
  /* stat figure scales to the cell (container query) and stays on one line; number/accent split is in StatFigure */
  .sb-cell.stat .v { font-size: clamp(18px, 16cqi, 34px); white-space: nowrap; }

  @media (max-width: 1100px) { .sb-board { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .sb-board { grid-template-columns: 1fr; } }
</style>
