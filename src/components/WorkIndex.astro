---
/**
 * WorkIndex.astro — the single, filterable-in-spirit work index with a sticky
 * live preview pane. Hover/focus a row to swap the preview image + meta.
 *
 * Client vs concept is a typed facet on each row (never separate sections).
 * Data here is the home teaser set; the future /work page + content collection
 * will own the canonical list. Covers resolve from the R2 CDN.
 *
 * NOTE: copy + the project set are placeholder until the content collection
 * lands (CLAUDE.md Phase 4). No metrics or claims are introduced here.
 */
import SectionLabel from './SectionLabel.astro';

const CDN = 'https://cdn.mehtapratik.com/covers';

type Project = {
  n: string;
  name: string;
  type: 'client' | 'concept';
  disc: string; // short, shown in the row
  year: string;
  slug: string; // cover file slug
  detail: string; // full discipline line, shown in the preview
};

const projects: Project[] = [
  { n: '01', name: 'SPORTIME Clubs', type: 'client', disc: 'Brand · Campaign', year: '2023', slug: 'sportime-clubs', detail: 'Brand · Campaign · Motion · Photo · Client' },
  { n: '02', name: 'The Ninth', type: 'concept', disc: 'Brand · UI · AI', year: '2024', slug: 'the-ninth', detail: 'Brand · UI/UX · AI · Motion · Concept' },
  { n: '03', name: 'Level', type: 'concept', disc: 'UI/UX · Product', year: '2024', slug: 'level', detail: 'UI/UX · Product · Motion · Concept' },
  { n: '04', name: 'WISP', type: 'concept', disc: 'UI · AI · Motion', year: '2024', slug: 'wisp', detail: 'UI/UX · AI · Motion · Concept' },
  { n: '05', name: 'DealNews', type: 'client', disc: 'UI/UX · Brand', year: '2021', slug: 'dealnews', detail: 'UI/UX · Brand · Social · Client' },
  { n: '06', name: 'Richard Attias & Associates', type: 'client', disc: 'Production · Brand', year: '2019', slug: 'raa', detail: 'Production · Brand · Print · Broadcast · Client' },
  { n: '07', name: 'Pipeline Medical', type: 'client', disc: 'Brand · Product', year: '2018', slug: 'pipeline-medical', detail: 'Brand · Product · UI/UX · Client' },
  { n: '08', name: 'Agency FiveEighty', type: 'client', disc: 'Motion · Brand', year: '2020', slug: 'agency-fiveeighty', detail: 'Motion · Brand · Campaign · Client' },
  { n: '09', name: 'The Forest Road Company', type: 'client', disc: 'Brand · Motion', year: '2021', slug: 'frc', detail: 'Brand · Motion · Client' },
  { n: '10', name: 'SR Love & Care', type: 'client', disc: 'Brand · Leadership', year: '2016', slug: 'sr-love-and-care', detail: 'Brand · Leadership · Nonprofit · Client' },
];

const first = projects[0]!;
---

<section class="block" id="work">
  <SectionLabel code="02" title="The work · one index" more={{ href: '#work', label: 'View all →' }} />
  <div class="index-wrap">
    <div class="idx">
      <div class="idx-head"><span>#</span><span>Project</span><span>Discipline</span><span>Year</span></div>
      {
        projects.map((p, i) => (
          <a
            class:list={['idx-row', i === 0 && 'active']}
            href="#work"
            data-img={`${CDN}/${p.slug}-cover.webp`}
            data-t={p.name}
            data-d={p.detail}
          >
            <span class="ix">{p.n}</span>
            <span class="nm">
              <b>{p.name}</b>
              <span class:list={['ty', p.type === 'client' && 'client']}>
                {p.type === 'client' ? 'Client' : 'Concept'}
              </span>
            </span>
            <span class="disc">{p.disc}</span>
            <span class="yr">{p.year}</span>
          </a>
        ))
      }
    </div>
    <div class="preview">
      <div class="pv-img" id="pv-img"></div>
      <div class="pv-meta">
        <div class="pv-t" id="pv-t">{first.name}</div>
        <div class="pv-d" id="pv-d">{first.detail}</div>
      </div>
    </div>
  </div>
</section>

<script>
  // Work index -> sticky preview. Lazily builds + cross-fades cover images.
  const rows = [...document.querySelectorAll<HTMLAnchorElement>('.idx-row')];
  const pvImg = document.getElementById('pv-img');
  const pvT = document.getElementById('pv-t');
  const pvD = document.getElementById('pv-d');
  const imgs: Record<string, HTMLImageElement> = {};

  function setPreview(r: HTMLAnchorElement) {
    if (!pvImg || !pvT || !pvD) return;
    rows.forEach((x) => x.classList.remove('active'));
    r.classList.add('active');
    const src = r.dataset.img;
    if (!src) return;
    if (!imgs[src]) {
      const im = new Image();
      im.src = src;
      im.alt = r.dataset.t ?? '';
      pvImg.appendChild(im);
      imgs[src] = im;
    }
    pvImg.querySelectorAll('img').forEach((i) => i.classList.remove('show'));
    requestAnimationFrame(() => imgs[src]!.classList.add('show'));
    pvT.textContent = r.dataset.t ?? '';
    pvD.textContent = r.dataset.d ?? '';
  }

  rows.forEach((r) => {
    r.addEventListener('mouseenter', () => setPreview(r));
    r.addEventListener('focus', () => setPreview(r));
  });
  if (rows[0]) setPreview(rows[0]);
</script>

<style>
  .index-wrap { display: grid; grid-template-columns: 1fr 380px; gap: 48px; align-items: start; }
  .idx-head, .idx-row { display: grid; grid-template-columns: 34px 1.6fr 0.8fr 60px; gap: 16px; align-items: center; }
  .idx-head { padding: 12px 0; border-bottom: 1px solid var(--border); }
  .idx-head span { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); }
  .idx-row { padding: 20px 0; border-bottom: 1px solid var(--border); cursor: pointer; transition: padding-left .2s var(--ease-standard); }
  .idx-row:hover, .idx-row.active { padding-left: 10px; }
  .idx-row .ix { font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); }
  .idx-row.active .ix { color: var(--accent-text); }
  .idx-row .nm { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .idx-row .nm b { font-family: var(--font-sans); font-weight: 600; font-size: 20px; letter-spacing: -0.015em; color: var(--text-secondary); transition: color .2s var(--ease-standard); }
  .idx-row:hover .nm b, .idx-row.active .nm b { color: var(--text); }
  .idx-row .nm .ty { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 6px; border-radius: var(--radius-none); border: 1px solid var(--border-strong); color: var(--text-muted); }
  .idx-row .nm .ty.client { color: var(--accent-text); border-color: rgba(255, 90, 31, .35); }
  .idx-row .disc { font-family: var(--font-mono); font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); }
  .idx-row .yr { font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary); text-align: right; }
  .preview { position: sticky; top: 40px; border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); }
  .preview .pv-img { aspect-ratio: 4/3; overflow: hidden; position: relative; background: var(--surface-raised); }
  .preview .pv-img :global(img) { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity .32s var(--ease-standard); }
  .preview .pv-img :global(img.show) { opacity: 1; }
  .preview .pv-meta { padding: 18px; }
  .preview .pv-meta .pv-t { font-family: var(--font-display); font-weight: 600; font-size: 22px; letter-spacing: -0.02em; }
  .preview .pv-meta .pv-d { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text-muted); margin-top: 10px; line-height: 1.6; }

  @media (max-width: 1100px) {
    .index-wrap { grid-template-columns: 1fr; }
    .preview { display: none; }
  }
  @media (max-width: 560px) {
    .idx-head { display: none; }
    .idx-row { grid-template-columns: 24px 1fr; gap: 10px; }
    .idx-row .disc, .idx-row .yr { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .preview .pv-img :global(img) { transition: none; }
  }
</style>
