---
/**
 * CaseSectionHead.astro — case-study section header: `[ 0N ]` + uppercase
 * tracked title + flex rule line. Distinct from the home SectionLabel.
 */
interface Props {
  no: string;
  title: string;
}
const { no, title } = Astro.props;
---

<div class="cs-head">
  <span class="no">[ {no} ]</span>
  <h2>{title}</h2>
  <span class="rule"></span>
</div>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .cs-head h2 {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }
  .cs-head .no {
    font-family: var(--t-data-font); font-weight: var(--t-data-weight); letter-spacing: var(--t-data-track);
  }

  .cs-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 40px; }
  .cs-head .no { font-size: 12px; color: var(--accent-text); }
  .cs-head h2 { font-size: clamp(13px, 2vw, 15px); text-transform: uppercase; }
  .cs-head .rule { flex: 1; height: 1px; background: var(--border); }
</style>
