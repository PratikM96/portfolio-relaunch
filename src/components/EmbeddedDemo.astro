---
/**
 * EmbeddedDemo.astro — concept launcher. A tabbed island that previews the live
 * concept views and links into them: each tab is an anchor to its real view
 * under /concepts/[project]/, and the stage opens whichever view is previewed.
 * Hover/focus a tab to preview it in the stage; click to launch it live. The
 * `featured` view (the AI moment-clipper) is shown by default as the centerpiece.
 *
 * The script is generic over every .embed on the page.
 */
type Tab = {
  /** Tab label (e.g. "Clipper"). */
  label: string;
  /** Caption shown over the stage when active. */
  cap: string;
  /** Stage preview image for this view (/concepts/<slug>/preview-<view>.webp). */
  img: string;
  /** Live view URL under /concepts/[project]/. */
  href: string;
  /** Centerpiece view, shown by default. */
  featured?: boolean;
};
interface Props {
  heading: string;
  tabs: Tab[];
  /** "Open full demo" target (the concept index). */
  openHref: string;
  foot: string;
}
const { heading, tabs, openHref, foot } = Astro.props;
const featuredIndex = tabs.findIndex((t) => t.featured);
const activeIndex = featuredIndex >= 0 ? featuredIndex : 0;
const active = tabs[activeIndex] ?? tabs[0];
---

<div class="embed rev">
  <div class="ehead">
    <span class="el">{heading}</span>
    <a class="open" href={openHref}>Open full demo ↗</a>
  </div>
  <div class="etabs">
    {
      tabs.map((t, i) => (
        <a class:list={['etab', i === activeIndex && 'on']} href={t.href} data-cap={t.cap} data-img={t.img}>
          {t.label}
        </a>
      ))
    }
  </div>
  <a class="estage" href={active.href} aria-label={`Open the ${active.label} view`}>
    <img class="estage-img" src={active.img} alt={active.cap} />
    <div class="scrim"><span class="cap estage-cap">{active.cap}</span></div>
    <span class="estage-go">Open ↗</span>
  </a>
  <div class="efoot">{foot}</div>
</div>

<style>
  /* type tiers — family/weight/tracking only; rules below set size + colour */
  .embed .ehead .el,
  .embed .ehead .open,
  .embed .etabs .etab,
  .embed .estage .scrim .cap,
  .embed .estage .estage-go,
  .embed .efoot {
    font-family: var(--t-label-font); font-weight: var(--t-label-weight); letter-spacing: var(--t-label-track);
  }


  .embed { border: 1px solid var(--border-strong); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); margin-top: 24px; }
  .embed .ehead { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px 18px; border-bottom: 1px solid var(--border); background: var(--surface-raised); }
  .embed .ehead .el { font-size: 11px; text-transform: uppercase; color: var(--text-secondary); }
  .embed .ehead .open { font-size: 11px; text-transform: uppercase; color: var(--text); display: flex; align-items: center; gap: 7px; transition: color .2s var(--ease-standard); }
  .embed .ehead .open:hover { color: var(--accent-text); }
  .embed .etabs { display: flex; border-bottom: 1px solid var(--border); overflow-x: auto; }
  .embed .etabs .etab { font-size: 11px; text-transform: uppercase; color: var(--text-muted); background: none; border: none; border-bottom: 2px solid transparent; padding: 13px 18px; cursor: pointer; white-space: nowrap; transition: color .2s var(--ease-standard), border-color .2s var(--ease-standard); }
  .embed .etabs .etab:hover { color: var(--text-secondary); }
  .embed .etabs .etab.on { color: var(--text); border-bottom-color: var(--accent-fill); }
  .embed .estage { position: relative; display: block; aspect-ratio: var(--ratio-wide); overflow: hidden; }
  .embed .estage img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease-standard); }
  .embed .estage:hover img { transform: scale(1.02); }
  .embed .estage .scrim { position: absolute; inset: 0; display: flex; align-items: flex-end; padding: 18px; background: linear-gradient(0deg, rgba(11, 11, 10, .6), transparent 55%); pointer-events: none; }
  .embed .estage .scrim .cap { font-size: 10.5px; text-transform: uppercase; color: #fff; max-width: 60ch; }
  .embed .estage .estage-go { position: absolute; top: 14px; right: 14px; font-size: 10.5px; text-transform: uppercase; color: #fff; background: rgba(11, 11, 10, .55); backdrop-filter: blur(6px); padding: 5px 10px; border-radius: var(--radius-none); opacity: 0; transition: opacity .2s var(--ease-standard); }
  .embed .estage:hover .estage-go, .embed .estage:focus-visible .estage-go { opacity: 1; }
  .embed .efoot { padding: 13px 18px; font-size: 10.5px; text-transform: uppercase; color: var(--text-muted); border-top: 1px solid var(--border); }
</style>

<script is:inline>
  (function () {
    var embeds = Array.prototype.slice.call(document.querySelectorAll('.embed'));
    embeds.forEach(function (embed) {
      var tabs = Array.prototype.slice.call(embed.querySelectorAll('.etabs .etab'));
      var stage = embed.querySelector('.estage');
      var img = embed.querySelector('.estage-img');
      var cap = embed.querySelector('.estage-cap');
      function activate(tab) {
        tabs.forEach(function (x) { x.classList.remove('on'); });
        tab.classList.add('on');
        if (cap) cap.textContent = tab.dataset.cap;
        if (img && tab.dataset.img) img.src = tab.dataset.img;
        if (img) img.alt = tab.dataset.cap || '';
        if (stage) stage.setAttribute('href', tab.getAttribute('href'));
      }
      tabs.forEach(function (tab) {
        // hover/focus previews the view in the stage; click follows the link
        tab.addEventListener('mouseenter', function () { activate(tab); });
        tab.addEventListener('focus', function () { activate(tab); });
      });
    });
  })();
</script>
