---
/**
 * Base.astro — site-wide layout chrome for mehtapratik.com (One System).
 *
 * Owns: the <head> (no-flash theme script, font wiring, token + global CSS),
 * the console rail, the mobile bar, the footer, and the site-wide scripts
 * (theme toggle, NY clock, generic reveal-on-scroll, generic rail scroll-spy).
 *
 * The rail has two variants, selected by `variant`:
 *   - 'default'     — home/site chrome: stacked brandmark, role, numbered site
 *                     nav, readout (status + location + live clock + theme).
 *   - 'case-study'  — horizontal brandmark, back link, section-index nav
 *                     (scroll-spy), persistent project scoreboard + theme.
 * Everything else (mobile bar, footer, scripts) is shared, so the case study
 * is a prop variant of the rail, not a separate copy.
 *
 * Page content is slotted into .stage > .pad, footer appended after.
 */
import '../styles/tokens.css';
import '../styles/global.css';
import Brandmark from '../components/Brandmark.astro';

type RailSection = { ix: string; label: string; href: string };
type ScoreLine = { k: string; v: string; client?: boolean };

interface Props {
  /** <title> text. Falls back to the brand line. */
  title?: string;
  /** <meta name="description">. Optional. */
  description?: string;
  /** Rail mode. */
  variant?: 'default' | 'case-study';
  /** default rail: nav item to mark active (href without leading '#'). */
  activeNav?: string;
  /** case-study rail: section-index nav items (also drives scroll-spy). */
  sections?: RailSection[];
  /** case-study rail: persistent project scoreboard (Type/Role/Year). */
  scoreboard?: ScoreLine[];
  /** case-study rail + mobile: back link to the work index. */
  back?: { href: string; label: string };
}

const {
  title = 'Pratik Mehta · Creative & Marketing Strategist',
  description,
  variant = 'default',
  activeNav = 'home',
  sections = [],
  scoreboard = [],
  back = { href: '/#work', label: '← Index · all work' },
} = Astro.props;

const isCase = variant === 'case-study';

// Default rail nav — real page routes. `id` drives the active state per page
// (set via the `activeNav` prop), so each page highlights only its own item.
const nav = [
  { ix: '01', id: 'home', label: 'Home', href: '/' },
  { ix: '02', id: 'work', label: 'Work', href: '/work' },
  { ix: '03', id: 'about', label: 'About', href: '/about' },
  { ix: '04', id: 'brand', label: 'Brand', href: '/brand' },
  { ix: '05', id: 'journal', label: 'Journal', href: '/journal' },
  { ix: '06', id: 'contact', label: 'Contact', href: '/contact' },
];

const year = 2026; // static; avoids per-request Date() in the worker
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {/* Favicon bundle (One System brand). Files live in /public, served at root. */}
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Pratik" />
    <link rel="manifest" href="/site.webmanifest" />

    {/* no-flash: set theme before paint */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('pm-theme');
          if (!t) {
            t = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>

    {/* Fonts. Berkeley Mono @font-face is in tokens.css; the head links
        below load Clash (Fontshare) + JetBrains Mono fallback (Google). */}
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=clash-grotesk@400,600,700&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    {/* CONSOLE RAIL */}
    <aside class:list={['console', isCase && 'cs']}>
      {
        isCase ? (
          <Fragment>
            <a class="brand" href="/" aria-label="Pratik Mehta — home">
              <Brandmark size={26} title={undefined} />
            </a>
            <a class="back" href={back.href}>{back.label}</a>
            <nav class="cs-nav" id="cs-nav">
              {sections.map((s, i) => (
                <a href={s.href} class:list={[i === 0 && 'active']}>
                  <span class="ix">{s.ix}</span>
                  {s.label}
                </a>
              ))}
            </nav>
            <div class="spacer" />
            <div class="scoreboard">
              {scoreboard.map((l) => (
                <div class="line">
                  <span class="k">{l.k}</span>
                  <span class:list={['v', l.client && 'client']}>{l.v}</span>
                </div>
              ))}
              <div class="tg" role="group" aria-label="Color theme">
                <button data-set="dark" aria-pressed="true">Dark</button>
                <span class="sep">·</span>
                <button data-set="light" aria-pressed="false">Light</button>
              </div>
            </div>
          </Fragment>
        ) : (
          <Fragment>
            <a class="brand" href="/" aria-label="Pratik Mehta — home">
              <Brandmark size={26} title={undefined} />
              <span class="wm">Pratik<br />Mehta</span>
            </a>
            <div class="role">Creative &amp;<br />Marketing Strategist</div>
            <nav id="rail-nav">
              {nav.map((n) => (
                <a href={n.href} class={n.id === activeNav ? 'active' : undefined}>
                  <span class="ix">{n.ix}</span>
                  {n.label}
                </a>
              ))}
            </nav>
            {/* persistent about-me blurb (locked bio — Phase 4 chrome.md) */}
            <div class="rail-bio">
              <span class="bio-k">About</span>
              <p>Most of my work is making sure the creative and the marketing are actually solving the same problem.</p>
            </div>
            <div class="spacer" />
            <div class="readout">
              <div class="status"><span class="dot" />Open to roles</div>
              <div class="line"><span>Loc</span><b>New York</b></div>
              <div class="line"><span>Local</span><b id="clock">—</b></div>
              <div class="line theme-line">
                <span>Theme</span>
                <span class="tg" role="group" aria-label="Color theme">
                  <button data-set="dark" aria-pressed="true">Dark</button>
                  <span class="sep">·</span>
                  <button data-set="light" aria-pressed="false">Light</button>
                </span>
              </div>
            </div>
          </Fragment>
        )
      }
    </aside>

    {/* MOBILE BAR */}
    <div class="console-mobile">
      <a class="brand" href="/" aria-label="Pratik Mehta — home">
        <Brandmark size={18} title={undefined} />
        <span>Pratik Mehta</span>
      </a>
      <div class="mr">
        {
          isCase ? (
            <a href={back.href}>← Work</a>
          ) : (
            <Fragment>
              <a href="/work">Work</a>
              <a href="/contact">Contact</a>
            </Fragment>
          )
        }
        <span class="tg" role="group" aria-label="Color theme">
          <button data-set="dark" aria-pressed="true">Dark</button>
          <span class="sep">·</span>
          <button data-set="light" aria-pressed="false">Light</button>
        </span>
      </div>
    </div>

    <div class="stage" id="top">
      <div class="pad">
        <slot />

        <div class="foot">
          <span class="mono">© {year} Pratik Mehta · One system, end to end</span>
          <div class="fl">
            <a href="/work">Work</a>
            <a href="/about">About</a>
            <a href="/resume">Resume</a>
            <a href="/brand">Brand</a>
            <a href="/journal">Journal</a>
            <a href="/contact">Contact</a>
          </div>
        </div>
      </div>
    </div>

    {/* Site-wide: theme toggle + NY clock + reveal-on-scroll + rail scroll-spy */}
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var themeBtns = Array.prototype.slice.call(document.querySelectorAll('[data-set]'));
        function applyTheme(t) {
          root.setAttribute('data-theme', t);
          themeBtns.forEach(function (b) {
            b.setAttribute('aria-pressed', String(b.dataset.set === t));
          });
          try { localStorage.setItem('pm-theme', t); } catch (e) {}
        }
        themeBtns.forEach(function (b) {
          b.addEventListener('click', function () { applyTheme(b.dataset.set); });
        });
        applyTheme(root.getAttribute('data-theme') || 'dark');

        // follow live OS theme, but only until the visitor makes a manual choice
        try {
          var mq = window.matchMedia('(prefers-color-scheme: light)');
          mq.addEventListener('change', function (e) {
            var chosen = null;
            try { chosen = localStorage.getItem('pm-theme'); } catch (_) {}
            if (!chosen) {
              root.setAttribute('data-theme', e.matches ? 'light' : 'dark');
              themeBtns.forEach(function (b) {
                b.setAttribute('aria-pressed', String(b.dataset.set === root.getAttribute('data-theme')));
              });
            }
          });
        } catch (e) {}

        // live NY clock (only present on the default rail)
        var clk = document.getElementById('clock');
        var tick = function () {
          try {
            clk.textContent = new Date().toLocaleTimeString('en-US', {
              timeZone: 'America/New_York', hour: '2-digit', minute: '2-digit',
            });
          } catch (e) { clk.textContent = '—'; }
        };
        if (clk) { tick(); setInterval(tick, 30000); }

        // reveal-on-scroll for any .rev element on the page
        var io = new IntersectionObserver(function (es) {
          es.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
        Array.prototype.slice.call(document.querySelectorAll('.rev')).forEach(function (el) { io.observe(el); });

        // rail scroll-spy — generic over whichever rail nav exists
        var navLinks = Array.prototype.slice.call(document.querySelectorAll('#rail-nav a, #cs-nav a'));
        if (navLinks.length) {
          var ids = navLinks
            .map(function (a) { return (a.getAttribute('href') || '').replace(/^#/, ''); })
            .filter(function (id) { return id && id.charAt(0) !== '/'; });
          var secs = ids.map(function (id) { return document.getElementById(id); })
            .filter(function (el) { return el; });
          var spy = new IntersectionObserver(function (es) {
            es.forEach(function (e) {
              if (e.isIntersecting) {
                var id = e.target.id;
                navLinks.forEach(function (a) {
                  a.classList.toggle('active', a.getAttribute('href') === '#' + id);
                });
              }
            });
          }, { rootMargin: '-35% 0px -55% 0px' });
          secs.forEach(function (s) { spy.observe(s); });
        }
      })();
    </script>
  </body>
</html>
