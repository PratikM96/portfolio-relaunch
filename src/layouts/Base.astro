---
/**
 * Base.astro — site-wide layout chrome for mehtapratik.com (One System).
 *
 * Owns: the <head> (no-flash theme script, font wiring, token + global CSS),
 * the console rail, the mobile bar, the footer, and the site-wide scripts
 * (theme toggle, NY clock, generic reveal-on-scroll, generic rail scroll-spy).
 *
 * The rail has two variants, selected by `variant`:
 *   - 'default'     — home/site chrome: stacked brandmark, role, numbered site
 *                     nav, readout (status + location + live clock + theme).
 *   - 'case-study'  — horizontal brandmark, back link, section-index nav
 *                     (scroll-spy), persistent project scoreboard + theme.
 * Everything else (mobile bar, footer, scripts) is shared, so the case study
 * is a prop variant of the rail, not a separate copy.
 *
 * Page content is slotted into .stage > .pad, footer appended after.
 */
import '../styles/tokens.css';
import '../styles/global.css';
import Brandmark from '../components/Brandmark.astro';

type RailSection = { ix: string; label: string; href: string };
// `accent` marks a value as real work, which earns the signal colour; concept
// scope never does (CLAUDE.md). Was `client` before the engagement facet split.
type ScoreLine = { k: string; v: string; accent?: boolean };

interface Props {
  /** <title> text. Falls back to the brand line. */
  title?: string;
  /** <meta name="description">. Optional. */
  description?: string;
  /** Rail mode. */
  variant?: 'default' | 'case-study';
  /** default rail: nav item to mark active (href without leading '#'). */
  activeNav?: string;
  /** case-study rail: section-index nav items (also drives scroll-spy). */
  sections?: RailSection[];
  /** case-study rail: persistent project scoreboard (Type/Role/Year). */
  scoreboard?: ScoreLine[];
  /** case-study rail + mobile: back link to the work index. */
  back?: { href: string; label: string };
  /** OG/Twitter share image, root-relative; resolved to an absolute URL. Defaults to /og/default.png. */
  image?: string;
  /** LCP image to preload with high priority (root-relative), e.g. the home hero poster. */
  preloadImage?: string;
  /** og:type — 'website' (default) | 'article' | 'profile'. */
  ogType?: string;
  /** Emit a robots noindex directive (e.g. the 404 page). */
  noindex?: boolean;
  /** Extra JSON-LD @graph nodes (CreativeWork, BlogPosting, BreadcrumbList) merged with the site Person + WebSite. */
  schema?: Record<string, unknown>[];
}

const {
  title = 'Pratik Mehta · Creative Marketing Lead',
  description,
  variant = 'default',
  activeNav = 'home',
  sections = [],
  scoreboard = [],
  back = { href: '/work', label: '← Index · all work' },
  image = '/og/default.png',
  preloadImage,
  ogType = 'website',
  noindex = false,
  schema = [],
} = Astro.props;

const isCase = variant === 'case-study';
// Mobile drawer reuses the full site nav; case studies live under /work, so
// highlight Work there since they don't pass an explicit activeNav.
const drawerActive = isCase ? 'work' : activeNav;

// Default rail nav — real page routes. `id` drives the active state per page
// (set via the `activeNav` prop), so each page highlights only its own item.
const nav = [
  { ix: '01', id: 'home', label: 'Home', href: '/' },
  { ix: '02', id: 'work', label: 'Work', href: '/work' },
  { ix: '03', id: 'about', label: 'About', href: '/about' },
  { ix: '04', id: 'brand', label: 'Brand', href: '/brand' },
  { ix: '05', id: 'journal', label: 'Journal', href: '/journal' },
  { ix: '06', id: 'contact', label: 'Contact', href: '/contact' },
];

const year = 2026; // static; avoids per-request Date() in the worker

// Absolute URLs for canonical + share cards. Astro.site is the production
// domain, so these read mehtapratik.com even when the build is served from staging.
// Strip the .html that the 'file' build format leaves on Astro.url.pathname,
// and collapse index/root, so canonical + og:url match how Cloudflare serves
// these: no extension, no trailing slash (e.g. /work/dealnews, / for home).
const cleanPath = Astro.url.pathname.replace(/index\.html$/, '').replace(/\.html$/, '').replace(/\/$/, '') || '/';
const canonical = new URL(cleanPath, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

// Structured data: a site-wide Person + WebSite graph, plus any per-page nodes
// (CreativeWork / BlogPosting / BreadcrumbList) passed via the `schema` prop.
const origin = Astro.site ? Astro.site.origin : 'https://mehtapratik.com';
const ldGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${origin}/#pratik`,
      name: 'Pratik Mehta',
      url: `${origin}/`,
      jobTitle: 'Creative Marketing Lead',
      email: 'mailto:mehtadpratik@gmail.com',
      image: `${origin}/og/default.png`,
      address: { '@type': 'PostalAddress', addressLocality: 'New York', addressRegion: 'NY', addressCountry: 'US' },
      alumniOf: { '@type': 'CollegeOrUniversity', name: 'New York University' },
      sameAs: ['https://linkedin.com/in/pratikm96', 'https://instagram.com/pratikm96', 'https://x.com/pratikm96'],
    },
    {
      '@type': 'WebSite',
      '@id': `${origin}/#website`,
      name: 'Pratik Mehta',
      url: `${origin}/`,
      publisher: { '@id': `${origin}/#pratik` },
    },
    ...schema,
  ],
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Pratik Mehta · Journal" href="/rss.xml" />
    {noindex && <meta name="robots" content="noindex, follow" />}

    {/* Open Graph + Twitter share cards. Image is a same-origin /og/*.png at
        1200x630; each page passes its own via the `image` prop, default otherwise. */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Pratik Mehta" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@pratikm96" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    {/* Browser UI tint per theme */}
    <meta name="theme-color" content="#0B0B0A" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#FBFAF6" media="(prefers-color-scheme: light)" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(ldGraph)} />

    {/* Favicon bundle (One System brand). Files live in /public, served at root. */}
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Pratik" />
    <link rel="manifest" href="/site.webmanifest" />

    {/* no-flash: set theme before paint */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('pm-theme');
          if (!t) {
            t = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>

    {/* Fonts: all self-hosted, same-origin (@font-face in tokens.css). No
        third-party font CDNs. Preload only the above-the-fold faces — display
        700 (h1), grotesk 400 (body), mono 400 (labels); the rest load on use. */}
    <link rel="preload" href="/fonts/ClashDisplay-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ClashGrotesk-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/TX-02-Regular.woff2" as="font" type="font/woff2" crossorigin />

    {/* LCP image (e.g. home hero poster): discovered late in the DOM, so preload
        it high-priority to start the fetch before CSS/fonts resolve. Opt-in per
        page via the `preloadImage` prop; omitted pages emit nothing. */}
    {preloadImage && (
      <link rel="preload" href={preloadImage} as="image" fetchpriority="high" />
    )}
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <style>
      .skip-link { position: fixed; top: 10px; left: 10px; z-index: 99999; padding: 10px 16px; border-radius: 8px; background: var(--surface-raised); color: var(--text); font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; text-decoration: none; transform: translateY(-160%); transition: transform 0.18s var(--ease-standard); }
      .skip-link:focus { transform: none; outline: 2px solid var(--accent-fill); outline-offset: 2px; }
    </style>
    {/* CONSOLE RAIL */}
    <aside class:list={['console', isCase && 'cs']}>
      {
        isCase ? (
          <Fragment>
            <a class="brand" href="/" aria-label="Pratik Mehta - home">
              <Brandmark size={26} title={undefined} />
            </a>
            <a class="back" href={back.href}>{back.label}</a>
            <nav class="cs-nav" id="cs-nav">
              {sections.map((s, i) => (
                <a href={s.href} class:list={[i === 0 && 'active']}>
                  <span class="ix">{s.ix}</span>
                  {s.label}
                </a>
              ))}
            </nav>
            {/* optional rail extras (journal fills this: more posts + author bio).
                Renders nothing on work case studies, which don't provide the slot. */}
            <slot name="rail" />
            <div class="spacer" />
            <div class="scoreboard">
              {scoreboard.map((l) => (
                <div class="line">
                  <span class="k">{l.k}</span>
                  <span class:list={['v', l.accent && 'accent']}>{l.v}</span>
                </div>
              ))}
              <div class="tg" role="group" aria-label="Color theme">
                <button data-set="dark" aria-pressed="true">Dark</button>
                <span class="sep">·</span>
                <button data-set="light" aria-pressed="false">Light</button>
              </div>
            </div>
          </Fragment>
        ) : (
          <Fragment>
            <a class="brand" href="/" aria-label="Pratik Mehta - home">
              <Brandmark size={26} title={undefined} />
              <span class="wm">Pratik<br />Mehta</span>
            </a>
            <div class="role">Creative Marketing<br />Lead</div>
            <nav id="rail-nav">
              {nav.map((n) => (
                <a href={n.href} class={n.id === activeNav ? 'active' : undefined}>
                  <span class="ix">{n.ix}</span>
                  {n.label}
                </a>
              ))}
            </nav>
            {/* persistent about-me blurb (locked bio — System Master) */}
            <div class="rail-bio">
              <span class="bio-k">About</span>
              <p>Most of my work is making sure the creative and the marketing are actually solving the same problem.</p>
            </div>
            <div class="spacer" />
            <div class="readout">
              <div class="status"><span class="dot" />Open to roles</div>
              <div class="line"><span>Loc</span><b>New York</b></div>
              <div class="line"><span>Local</span><b id="clock">··</b></div>
              <div class="line theme-line">
                <span>Theme</span>
                <span class="tg" role="group" aria-label="Color theme">
                  <button data-set="dark" aria-pressed="true">Dark</button>
                  <span class="sep">·</span>
                  <button data-set="light" aria-pressed="false">Light</button>
                </span>
              </div>
            </div>
          </Fragment>
        )
      }
    </aside>

    {/* MOBILE BAR */}
    <div class="console-mobile">
      <a class="brand" href="/" aria-label="Pratik Mehta - home">
        <Brandmark size={18} title={undefined} />
        <span>Pratik Mehta</span>
      </a>
      <button
        class="menu-btn"
        id="menu-open"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        {/* 2×2 node grid — echoes the brandmark's node geometry */}
        <span /><span /><span /><span />
      </button>
    </div>

    {/* MOBILE DRAWER — full-screen nav (only rendered ≤900px) */}
    <div class="m-drawer" id="mobile-drawer" aria-hidden="true">
      <div class="m-drawer-head">
        <a class="brand" href="/" aria-label="Pratik Mehta - home">
          <Brandmark size={18} title={undefined} />
          <span>Pratik Mehta</span>
        </a>
        <button class="menu-close" id="menu-close" aria-label="Close menu">✕</button>
      </div>
      <nav class="m-nav">
        {nav.map((n) => (
          <a href={n.href} class={n.id === drawerActive ? 'active' : undefined}>
            <span class="ix">{n.ix}</span>
            {n.label}
          </a>
        ))}
        <a href="/resume"><span class="ix">07</span>Resume</a>
      </nav>
      <div class="m-readout">
        <div class="status"><span class="dot" />Open to roles</div>
        <div class="line"><span>Loc</span><b>New York</b></div>
        <div class="line theme-line">
          <span>Theme</span>
          <span class="tg" role="group" aria-label="Color theme">
            <button data-set="dark" aria-pressed="true">Dark</button>
            <span class="sep">·</span>
            <button data-set="light" aria-pressed="false">Light</button>
          </span>
        </div>
      </div>
    </div>

    <div class="stage" id="top">
      <div class="pad">
        <main id="main">
          <slot />
        </main>

        <footer class="foot">
          <span class="mono">© {year} Pratik Mehta · One system, end to end</span>
          <div class="fl">
            <a href="/work">Work</a>
            <a href="/about">About</a>
            <a href="/resume">Resume</a>
            <a href="/brand">Brand</a>
            <a href="/journal">Journal</a>
            <a href="/contact">Contact</a>
            <a href="/privacy">Privacy</a>
            <button type="button" class="foot-cookies" data-consent-reopen>Cookies</button>
          </div>
        </footer>
      </div>
    </div>

    {/* Cookie consent + gated Google Analytics (GA4). gtag loads only after Accept. */}
    <div class="consent" id="consent" hidden>
      <p class="consent-txt">Google Analytics measures site traffic. No ads, no cross-site tracking. <a href="/privacy">Privacy</a></p>
      <div class="consent-btns">
        <button type="button" data-consent="deny">Decline</button>
        <button type="button" class="primary" data-consent="grant">Accept</button>
      </div>
    </div>
    <style>
      .consent { position: fixed; left: 16px; right: 16px; bottom: 16px; z-index: 9998; max-width: 700px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: center; gap: 12px 22px; padding: 16px 20px; background: var(--surface-raised); border: 1px solid var(--border-strong); border-radius: 14px; box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.55); }
      .consent[hidden] { display: none; }
      .consent-txt { flex: 1; min-width: 260px; margin: 0; font-size: 13px; line-height: 1.5; color: var(--text-secondary); text-wrap: balance; }
      .consent-txt a { color: var(--accent-text); text-decoration: underline; }
      .consent-btns { display: flex; gap: 10px; flex: none; }
      .consent button { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; padding: 9px 16px; border-radius: 999px; cursor: pointer; border: 1px solid var(--border-strong); background: transparent; color: var(--text); transition: border-color 0.18s var(--ease-standard), background 0.18s var(--ease-standard); }
      .consent button:hover { border-color: var(--text); }
      .consent button.primary { background: var(--accent-fill); border-color: var(--accent-fill); color: var(--on-accent); }
      .consent button:focus-visible { outline: 2px solid var(--accent-fill); outline-offset: 2px; }
      .foot-cookies { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-secondary); background: none; border: 0; padding: 0; cursor: pointer; }
      .foot-cookies:hover { color: var(--text); }
    </style>
    {/* Consent/GA gate + site chrome (theme toggle, drawer, NY clock,
        reveal-on-scroll, rail scroll-spy). Bundled module scripts, NOT
        is:inline: Astro hoists both imports into one hashed, cached file
        shared across the whole site instead of re-emitting ~5.8 KB of JS into
        every page's HTML. The only pre-paint script is the no-flash theme set
        above, which stays inline. */}
    <script>
      import '../scripts/consent.ts';
      import '../scripts/site-chrome.ts';
    </script>
  </body>
</html>
