# Cloudflare _headers — security + caching defaults.
# The @astrojs/cloudflare adapter APPENDS its own immutable rule for /_astro/*
# to this file at build, so hashed asset caching is handled there; the rules
# below cover everything else. No Content-Security-Policy yet: a strict CSP
# would break the inline no-flash theme script and the hero/rail inline
# scripts without a nonce/hash pass. Add a report-only policy first if wanted.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Self-hosted fonts are content-hashed at the filename level and never change.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Hero video + poster are versioned by slug folder; cache hard.
/hero/*
  Cache-Control: public, max-age=31536000, immutable
